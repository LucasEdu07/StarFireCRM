<Window x:Class="ExtintorCrm.App.Presentation.ExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar dados"
        Width="580"
        MinHeight="620"
        MaxHeight="860"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Exportar dados"
                           Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Border Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Exportar dados"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Escolha o conjunto de dados, formato e campos desejados antes de confirmar."
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextSecondary}" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Exportar"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}" />
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding EntityOptions}"
                                  SelectedItem="{Binding SelectedEntity, Mode=TwoWay}" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Formato"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondary}" />
                        <RadioButton Grid.Column="2"
                                     GroupName="ExportFormat"
                                     IsChecked="{Binding IsExcel, Mode=TwoWay}"
                                     Content="Excel (.xlsx)"
                                     Foreground="{DynamicResource TextPrimary}" />
                        <RadioButton Grid.Column="4"
                                     GroupName="ExportFormat"
                                     IsChecked="{Binding IsCsv, Mode=TwoWay}"
                                     Content="CSV (.csv)"
                                     Foreground="{DynamicResource TextPrimary}" />
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource SecondaryButton}"
                                Height="34"
                                MinWidth="132"
                                Margin="0,0,10,0"
                                Click="PresetPadrao_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8D2;" />
                                <TextBlock Text="Preset padrão" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Height="34"
                                MinWidth="146"
                                Click="PresetFinanceiro_Click"
                                Visibility="{Binding IsFinanceiroVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xEAFD;" />
                                <TextBlock Text="Preset financeiro" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="4"
                            Background="{DynamicResource SurfaceMuted}"
                            BorderBrush="{DynamicResource ControlBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Campos para exportação"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimary}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="32"
                                        Padding="10,0"
                                        MinWidth="126"
                                        Click="SelecionarTodos_Click">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8FB;" />
                                        <TextBlock Text="Selecionar todos" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="3"
                                        Style="{StaticResource SecondaryButton}"
                                        Height="32"
                                        Padding="10,0"
                                        MinWidth="120"
                                        Click="LimparSelecao_Click">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE894;" />
                                        <TextBlock Text="Limpar seleção" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <TextBlock Grid.Row="1"
                                       Margin="0,8,0,0"
                                       Text="{Binding SelectedFieldSummary}"
                                       Foreground="{DynamicResource TextSecondary}" />
                            <ScrollViewer Grid.Row="2" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FieldOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Style="{StaticResource ModernCheckBox}"
                                                      Margin="0,0,0,8"
                                                      Content="{Binding Label}"
                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="5"
                            Background="{DynamicResource SurfaceMuted}"
                            BorderBrush="{DynamicResource ControlBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Preview (3 primeiras linhas)"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" />
                            <DataGrid Grid.Row="1"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource ExcelPreviewDataGrid}"
                                      AutoGenerateColumns="True"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserReorderColumns="False"
                                      CanUserResizeColumns="False"
                                      CanUserSortColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      MinHeight="130"
                                      MaxHeight="170"
                                      ItemsSource="{Binding PreviewTable.DefaultView}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="6" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0"
                                  Style="{StaticResource ModernCheckBox}"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding SaveAsDefault, Mode=TwoWay}"
                                  Content="Salvar seleção como padrão" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}" Width="122" IsCancel="True" Margin="0,0,10,0">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                                    <TextBlock Text="Cancelar" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource PrimaryButton}" Width="130" IsDefault="True" Click="Confirmar_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8A5;" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                    <TextBlock Text="Continuar" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>


