                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="ItemContainerStyle" Value="{StaticResource ClientesFilterComboBoxItemStyle}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid SnapsToDevicePixels="True">
                                <ToggleButton x:Name="DropDownToggle"
                                              Focusable="False"
                                              FocusVisualStyle="{x:Null}"
                                              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              ClickMode="Press"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0">
                                    <Border x:Name="Root"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="34" />
                                            </Grid.ColumnDefinitions>
                                            <ContentPresenter Grid.Column="0"
                                                              Margin="11,0,8,0"
                                                              VerticalAlignment="Center"
                                                              HorizontalAlignment="Left"
                                                              Content="{TemplateBinding SelectionBoxItem}"
                                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                            <Border x:Name="ChevronPlate"
                                                    Grid.Column="1"
                                                    Margin="0,4,4,4"
                                                    Background="{DynamicResource SurfaceMuted}"
                                                    BorderBrush="{DynamicResource BorderSubtle}"
                                                    BorderThickness="1"
                                                    CornerRadius="7">
                                                <TextBlock x:Name="ChevronIcon"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           FontSize="10"
                                                           Text="&#xE70D;"
                                                           Foreground="{TemplateBinding Foreground}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </ToggleButton>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade">
                                    <Border Margin="0,7,0,0"
                                            MinWidth="{TemplateBinding ActualWidth}"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource BorderStrong}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="5"
                                            Effect="{StaticResource SoftShadow}">
                                        <ScrollViewer MaxHeight="260"
                                                      CanContentScroll="True">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                    <Setter TargetName="ChevronPlate" Property="Background" Value="{DynamicResource AccentBlueBg}" />
                                    <Setter TargetName="ChevronPlate" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                    <Setter TargetName="ChevronPlate" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                </Trigger>
                                <Trigger SourceName="DropDownToggle" Property="IsChecked" Value="True">
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                                    <Setter TargetName="ChevronPlate" Property="Background" Value="{DynamicResource AccentBlueBg}" />
                                    <Setter TargetName="ChevronPlate" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                    <Setter TargetName="ChevronIcon" Property="Foreground" Value="{DynamicResource AccentBlueFg}" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.62" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

