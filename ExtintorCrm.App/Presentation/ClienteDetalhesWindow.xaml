<Window x:Class="ExtintorCrm.App.Presentation.ClienteDetalhesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ExtintorCrm.App.Presentation.Controls"
        Title="Perfil do Cliente"
        Height="780"
        Width="1120"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0"
        Loaded="Window_Loaded">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.22" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SmallValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Margin" Value="0,2,0,12" />
        </Style>

        <Style x:Key="StatusChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="{DynamicResource BadgeMutedBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Ativo">
                    <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatusChipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BadgeMutedFg}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Ativo">
                    <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SituacaoBadge" TargetType="Border">
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BadgeMutedBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ExtintorBadgeNivel}" Value="OK">
                    <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ExtintorBadgeNivel}" Value="Vencendo">
                    <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ExtintorBadgeNivel}" Value="Critico">
                    <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InnerTabControlStyle" TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource SurfaceBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6,4">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1" Margin="0,10,0,0" x:Name="PART_SelectedContentHost" ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InnerTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,8,0"
                                CornerRadius="8"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBackground}" />
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryRed}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PagamentoRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVencido}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PagamentoBadge" TargetType="Border">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusNivel}" Value="Vencendo">
                    <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusNivel}" Value="Critico">
                    <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PagamentoBadgeText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusNivel}" Value="Vencendo">
                    <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusNivel}" Value="Critico">
                    <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryWhenEditModeButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryWhenEditModeButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryWhenReadModeButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenEditModeElement" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenReadModeElement" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MarkdownRibbonHost" TargetType="Border">
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Padding" Value="10,8,10,6" />
        </Style>

        <Style x:Key="MarkdownRibbonButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>

        <Style x:Key="MarkdownRibbonGlyph" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MarkdownRibbonLabel" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style x:Key="MarkdownRibbonGroupTitle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="MarkdownQuickActionButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="42" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="Background" Value="{DynamicResource CardBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource SurfaceBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Perfil do Cliente"
                           Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22" Background="{DynamicResource SurfaceBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionCard}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding NomeFantasia}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="Visualize e edite os dados do cliente em um único lugar."
                                   Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,4,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Telefone:" Style="{StaticResource SmallLabel}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding TelefoneResumo}" Margin="0,0,16,0" />
                            <TextBlock Text="Cidade:" Style="{StaticResource SmallLabel}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CidadeResumo}" Margin="0,0,16,0" />
                            <TextBlock Text="Próximo vencimento:" Style="{StaticResource SmallLabel}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding ProximoVencimento}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource StatusChip}" VerticalAlignment="Top">
                        <TextBlock Text="{Binding Status}" Style="{StaticResource StatusChipText}" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Dados do cliente" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />

                            <TextBlock Text="CPF/CNPJ" Style="{StaticResource SmallLabel}" />
                            <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,2,0,12" Text="{Binding CPF, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                            <TextBlock Text="Telefone" Style="{StaticResource SmallLabel}" />
                            <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,2,0,12" Text="{Binding Telefone1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                        <TextBlock Text="E-mail" Style="{StaticResource SmallLabel}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,2,0,12" Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                        <TextBlock Text="Contato" Style="{StaticResource SmallLabel}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,2,0,12" Text="{Binding Contato, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                        <TextBlock Text="Razão social" Style="{StaticResource SmallLabel}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,2,0,12" Text="{Binding RazaoSocial, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                        <TextBlock Text="Endereço" Style="{StaticResource SmallLabel}" />
                        <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,2,0,12" Text="{Binding Endereco, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                        <TextBlock Text="Cidade / UF" Style="{StaticResource SmallLabel}" />
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="66" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource ModernTextBox}" Height="38" Text="{Binding Cidade, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />
                            <TextBox Grid.Column="2" Style="{StaticResource ModernTextBox}" Height="38" MaxLength="2" Text="{Binding UF, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />
                        </Grid>

                        <TextBlock Text="Status" Style="{StaticResource SmallLabel}" />
                        <Grid Margin="0,2,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Ativo"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SmallLabel}">
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                        <Setter Property="FontWeight" Value="Normal" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAtivo}" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <controls:ThemeRockerSwitchControl x:Name="PerfilClienteStatusRockerControl"
                                                               Grid.Column="2"
                                                               LeftLabel="✔"
                                                               RightLabel="✖"
                                                               ToolTip="Ativo (✔) / Inativo (✖)"
                                                               IsChecked="{Binding IsAtivo, Mode=TwoWay}"
                                                               IsEnabled="{Binding IsEditMode}" />

                            <TextBlock Grid.Column="4"
                                       Text="Inativo"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource SmallLabel}">
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                        <Setter Property="FontWeight" Value="Normal" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsAtivo}" Value="False">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                            <TextBlock Text="Data de cadastro" Style="{StaticResource SmallLabel}" />
                            <TextBlock Text="{Binding CriadoEm, StringFormat=dd/MM/yyyy}" Style="{StaticResource SmallValue}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                        <TabControl Style="{StaticResource InnerTabControlStyle}" ItemContainerStyle="{StaticResource InnerTabItemStyle}">
                        <TabItem Header="Extintores">
                            <StackPanel>
                                <TextBlock Text="Vencimento dos extintores" Style="{StaticResource SmallLabel}" />
                                <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                            Margin="0,6,0,12"
                                            SelectedDate="{Binding VencimentoExtintores, Mode=TwoWay}"
                                            IsEnabled="{Binding IsEditMode}" />

                                <TextBlock Text="Tipo" Style="{StaticResource SmallLabel}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,6,0,12" Text="{Binding Tipo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                                <TextBlock Text="Status da recarga" Style="{StaticResource SmallLabel}" />
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Height="38"
                                          Margin="0,6,0,12"
                                          IsEnabled="{Binding IsEditMode}"
                                          SelectedValuePath="Content"
                                          SelectedValue="{Binding StatusRecarga, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Não informado" />
                                    <ComboBoxItem Content="Em dia" />
                                    <ComboBoxItem Content="Pendente" />
                                    <ComboBoxItem Content="Vencido" />
                                </ComboBox>

                                <Border Style="{StaticResource SituacaoBadge}" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding ExtintorBadgeTexto}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ExtintorBadgeNivel}" Value="OK">
                                                        <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ExtintorBadgeNivel}" Value="Vencendo">
                                                        <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ExtintorBadgeNivel}" Value="Critico">
                                                        <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Alvará">
                            <StackPanel>
                                <TextBlock Text="Nº do alvará" Style="{StaticResource SmallLabel}" />
                                <TextBox Style="{StaticResource ModernTextBox}" Height="38" Margin="0,6,0,12" Text="{Binding NumeroAlvara, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding IsEditMode}" />

                                <TextBlock Text="Status do alvará" Style="{StaticResource SmallLabel}" />
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Height="38"
                                          Margin="0,6,0,12"
                                          IsEnabled="{Binding IsEditMode}"
                                          SelectedValuePath="Content"
                                          SelectedValue="{Binding StatusAlvara, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Não informado" />
                                    <ComboBoxItem Content="Em dia" />
                                    <ComboBoxItem Content="Pendente" />
                                    <ComboBoxItem Content="Vencido" />
                                </ComboBox>

                                <TextBlock Text="Vencimento do alvará" Style="{StaticResource SmallLabel}" />
                                <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                            Margin="0,6,0,12"
                                            SelectedDate="{Binding VencimentoAlvara, Mode=TwoWay}"
                                            IsEnabled="{Binding IsEditMode}" />
                                <Border HorizontalAlignment="Left">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource SituacaoBadge}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AlvaraBadgeNivel}" Value="OK">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AlvaraBadgeNivel}" Value="Vencendo">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AlvaraBadgeNivel}" Value="Critico">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding AlvaraBadgeTexto}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AlvaraBadgeNivel}" Value="OK">
                                                        <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlvaraBadgeNivel}" Value="Vencendo">
                                                        <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding AlvaraBadgeNivel}" Value="Critico">
                                                        <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <Border Background="{DynamicResource SurfaceMuted}"
                                        BorderBrush="{DynamicResource BorderStrong}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="0,14,0,0"
                                        Padding="10,9">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Documentos do alvará"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}" />
                                            <TextBlock x:Name="AlvaraAnexosCountText"
                                                       Grid.Column="1"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="12"
                                                       Text="Nenhum documento anexado" />
                                        </Grid>

                                        <WrapPanel Grid.Row="1"
                                                   Orientation="Horizontal"
                                                   Margin="0,10,0,10">
                                            <Button x:Name="AnexarAlvaraButton"
                                                    Style="{StaticResource AccentButton}"
                                                    Height="34"
                                                    MinWidth="132"
                                                    Margin="0,0,10,0"
                                                    Click="AnexarAlvaraDocumento_Click">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE898;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    <TextBlock Text="Anexar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </StackPanel>
                                            </Button>

                                            <Button x:Name="AbrirAlvaraButton"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="34"
                                                    MinWidth="122"
                                                    Margin="0,0,10,0"
                                                    Click="AbrirAlvaraDocumento_Click">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8A7;" />
                                                    <TextBlock Text="Abrir" />
                                                </StackPanel>
                                            </Button>

                                            <Button x:Name="ExcluirAlvaraButton"
                                                    Style="{StaticResource DangerButton}"
                                                    Height="34"
                                                    MinWidth="122"
                                                    Click="ExcluirAlvaraDocumento_Click">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74D;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    <TextBlock Text="Excluir" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>

                                        <DataGrid x:Name="AlvaraAnexosDataGrid"
                                                  Grid.Row="2"
                                                  Style="{StaticResource CleanDataGrid}"
                                                  AutoGenerateColumns="False"
                                                  IsReadOnly="True"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  CanUserResizeRows="False"
                                                  SelectionMode="Single"
                                                  Height="170"
                                                  RowHeight="34"
                                                  ColumnHeaderHeight="36"
                                                  FontSize="12.4"
                                                  SelectionChanged="AlvaraAnexosDataGrid_SelectionChanged">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDocumento}" Width="130" />
                                                <DataGridTextColumn Header="Documento" Binding="{Binding NomeOriginal}" Width="2*" />
                                                <DataGridTextColumn Header="Tamanho" Binding="{Binding TamanhoTexto}" Width="110" />
                                                <DataGridTextColumn Header="Incluído em" Binding="{Binding CriadoEmTexto}" Width="150" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="Pagamentos">
                            <DataGrid Style="{StaticResource CleanDataGrid}"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      CanUserResizeRows="False"
                                      SelectionMode="Single"
                                      ItemsSource="{Binding Pagamentos}"
                                      RowStyle="{StaticResource PagamentoRowStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}" Width="2*" IsReadOnly="True" />
                                    <DataGridTemplateColumn Header="Vencimento" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DataVencimento, StringFormat=dd/MM/yyyy}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                                            SelectedDate="{Binding DataVencimento, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             IsEnabled="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Valor" Width="130">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding ValorFormatado}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Right" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                        <DataGridTemplateColumn.CellEditingTemplate>
                                            <DataTemplate>
                                                <TextBox Style="{StaticResource ModernTextBox}"
                                                         Text="{Binding Valor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}"
                                                         PreviewTextInput="ValorEditor_PreviewTextInput"
                                                         TextChanged="ValorEditor_TextChanged"
                                                         LostFocus="ValorEditor_LostFocus"
                                                         GotFocus="ValorEditor_GotFocus"
                                                         DataObject.Pasting="ValorEditor_Pasting"
                                                         IsEnabled="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellEditingTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Pago" Width="86">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox Style="{StaticResource ModernCheckBox}"
                                                          HorizontalAlignment="Center"
                                                          IsChecked="{Binding Pago, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Status" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource PagamentoBadge}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource PagamentoBadgeText}" Text="{Binding StatusTexto}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>

                        <TabItem Header="Observações">
                            <Grid>
                                <Border Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource ControlBorder}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Padding="14"
                                        Height="286"
                                        VerticalAlignment="Top"
                                        Style="{StaticResource VisibleWhenReadModeElement}">
                                    <controls:MarkdownViewerControl MarkdownText="{Binding Observacoes}" />
                                </Border>

                                <Grid Style="{StaticResource VisibleWhenEditModeElement}" VerticalAlignment="Top">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Row="0"
                                            Grid.ColumnSpan="3"
                                            Style="{StaticResource MarkdownRibbonHost}">
                                        <DockPanel LastChildFill="False" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal"
                                                        DockPanel.Dock="Left"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="Ações rápidas"
                                                           Style="{StaticResource SmallLabel}"
                                                           Margin="0,0,12,0" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="⟲" Tag="undo" Click="MarkdownTool_Click" ToolTip="Desfazer (Ctrl+Z)" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="⟳" Tag="redo" Click="MarkdownTool_Click" ToolTip="Refazer (Ctrl+Y)" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="H1" Tag="h1" Click="MarkdownTool_Click" ToolTip="Título" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="B" Tag="bold" Click="MarkdownTool_Click" ToolTip="Negrito" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="I" Tag="italic" Click="MarkdownTool_Click" ToolTip="Itálico" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="•" Tag="ul" Click="MarkdownTool_Click" ToolTip="Lista" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="Link" Tag="link" Click="MarkdownTool_Click" ToolTip="Link" />
                                                <Button Style="{StaticResource MarkdownQuickActionButton}" Content="&quot;" Tag="quote" Click="MarkdownTool_Click" ToolTip="Citação" />
                                            </StackPanel>

                                            <Button DockPanel.Dock="Right"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Height="38"
                                                    Width="162"
                                                    Margin="10,0,0,0"
                                                    Click="OpenMarkdownEditorModal_Click">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE70F;" />
                                                    <TextBlock Text="Editor Avançado" />
                                                </StackPanel>
                                            </Button>
                                        </DockPanel>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Grid.Column="0"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="246" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Editor .md"
                                                       Style="{StaticResource SmallLabel}"
                                                       Margin="0,0,0,8" />
                                            <TextBox x:Name="ObservacoesMarkdownEditor"
                                                     Grid.Row="1"
                                                     Text="{Binding Observacoes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Auto"
                                                     PreviewKeyDown="ObservacoesEditor_PreviewKeyDown"
                                                     FontFamily="Consolas"
                                                     FontSize="13"
                                                     Padding="10"
                                                     BorderBrush="{DynamicResource ControlBorder}"
                                                     BorderThickness="1"
                                                     Background="{DynamicResource InputBackground}"
                                                     Foreground="{DynamicResource TextPrimary}"
                                                     CaretBrush="{DynamicResource TextPrimary}"
                                                     IsEnabled="{Binding IsEditMode}" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2"
                                            Grid.Column="2"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="246" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Text="Prévia renderizada"
                                                       Style="{StaticResource SmallLabel}"
                                                       Margin="0,0,0,8" />
                                            <controls:MarkdownViewerControl Grid.Row="1"
                                                                            MarkdownText="{Binding Observacoes}" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <TextBlock x:Name="SaveStatusText"
                           Style="{StaticResource SmallLabel}"
                           Visibility="Collapsed"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />

                <Button Style="{StaticResource SecondaryButton}" Width="128" Margin="0,0,8,0" IsCancel="True">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8BB;" />
                        <TextBlock Text="Fechar" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource PrimaryWhenReadModeButton}" Width="174" Margin="0,0,8,0" Click="Editar_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE70F;" Foreground="{DynamicResource ButtonPrimaryFg}" />
                        <TextBlock Text="Editar no perfil" Foreground="{DynamicResource ButtonPrimaryFg}" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryWhenEditModeButton}" Width="154" Margin="0,0,8,0" Click="CancelarEdicao_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                        <TextBlock Text="Cancelar edição" />
                    </StackPanel>
                </Button>

                <Button x:Name="SalvarAlteracoesButton"
                        Style="{StaticResource PrimaryWhenEditModeButton}"
                        Width="174"
                        Click="Salvar_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74E;" Foreground="{DynamicResource ButtonPrimaryFg}" />
                        <TextBlock Text="Salvar alterações" Foreground="{DynamicResource ButtonPrimaryFg}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <Grid x:Name="MarkdownEditorOverlay"
              Grid.RowSpan="2"
              Panel.ZIndex="50"
              Visibility="Collapsed"
              Background="#8A000000"
              MouseDown="MarkdownOverlay_MouseDown">
            <Border Width="980"
                    Height="640"
                    Padding="16"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource ControlBorder}"
                    Background="{DynamicResource SurfaceBackground}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MouseDown="MarkdownModalCard_MouseDown">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Editor de Observações (.md)"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <Button Grid.Column="1"
                                Style="{StaticResource GhostButton}"
                                Width="38"
                                Height="34"
                                Click="CloseMarkdownEditorModal_Click"
                                ToolTip="Fechar editor">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE711;" />
                        </Button>
                    </Grid>

                    <Border Grid.Row="1" Style="{StaticResource MarkdownRibbonHost}" Margin="0,12,0,12">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Margin="0,0,10,0">
                                <WrapPanel>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="undo" Click="MarkdownToolModal_Click" ToolTip="Desfazer (Ctrl+Z)">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="⟲" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Desfazer" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="redo" Click="MarkdownToolModal_Click" ToolTip="Refazer (Ctrl+Y)">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="⟳" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Refazer" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="Histórico" Style="{StaticResource MarkdownRibbonGroupTitle}" />
                            </StackPanel>

                            <Border Width="1"
                                    Margin="0,4,10,4"
                                    Background="{DynamicResource ControlBorder}" />

                            <StackPanel Margin="0,0,10,0">
                                <WrapPanel>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="h1" Click="MarkdownToolModal_Click" ToolTip="Título principal">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="H1" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Título" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="h2" Click="MarkdownToolModal_Click" ToolTip="Subtítulo">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="H2" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Subtítulo" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="bold" Click="MarkdownToolModal_Click" ToolTip="Negrito">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="B" FontWeight="Bold" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Negrito" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="italic" Click="MarkdownToolModal_Click" ToolTip="Itálico">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="I" FontStyle="Italic" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Itálico" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="link" Click="MarkdownToolModal_Click" ToolTip="Inserir link">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" FontFamily="Segoe MDL2 Assets" Text="&#xE71B;" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Link" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="Texto" Style="{StaticResource MarkdownRibbonGroupTitle}" />
                            </StackPanel>

                            <Border Width="1"
                                    Margin="0,4,10,4"
                                    Background="{DynamicResource ControlBorder}" />

                            <StackPanel Margin="0,0,10,0">
                                <WrapPanel>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="ul" Click="MarkdownToolModal_Click" ToolTip="Lista com marcadores">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="•" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Lista" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="ol" Click="MarkdownToolModal_Click" ToolTip="Lista numerada">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="1." />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Numerada" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="quote" Click="MarkdownToolModal_Click" ToolTip="Citação">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="&quot;" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Citar" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="clear_formatting" Click="MarkdownToolModal_Click" ToolTip="Limpar formatação">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="Tx" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Limpar" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="Estrutura" Style="{StaticResource MarkdownRibbonGroupTitle}" />
                            </StackPanel>

                            <Border Width="1"
                                    Margin="0,4,10,4"
                                    Background="{DynamicResource ControlBorder}" />

                            <StackPanel>
                                <WrapPanel>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="duplicate_line" Click="MarkdownToolModal_Click" ToolTip="Duplicar linha (Ctrl+D)">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="+" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Duplicar" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="move_line_up" Click="MarkdownToolModal_Click" ToolTip="Mover linha para cima (Alt+↑)">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="↑" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Subir" />
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource MarkdownRibbonButton}" Tag="move_line_down" Click="MarkdownToolModal_Click" ToolTip="Mover linha para baixo (Alt+↓)">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MarkdownRibbonGlyph}" Text="↓" />
                                            <TextBlock Style="{StaticResource MarkdownRibbonLabel}" Text="Descer" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>
                                <TextBlock Text="Linha" Style="{StaticResource MarkdownRibbonGroupTitle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlBorder}"
                                Background="{DynamicResource CardBackground}"
                                Padding="12">
                            <TextBox x:Name="ObservacoesMarkdownEditorModal"
                                     Text="{Binding Observacoes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     PreviewKeyDown="ObservacoesEditor_PreviewKeyDown"
                                     FontFamily="Consolas"
                                     FontSize="14"
                                     Padding="10"
                                     BorderBrush="{DynamicResource ControlBorder}"
                                     BorderThickness="1"
                                     Background="{DynamicResource InputBackground}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     CaretBrush="{DynamicResource TextPrimary}"
                                     IsEnabled="{Binding IsEditMode}" />
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource ControlBorder}"
                                Background="{DynamicResource CardBackground}"
                                Padding="12">
                            <controls:MarkdownViewerControl MarkdownText="{Binding Observacoes}" />
                        </Border>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Style="{StaticResource SecondaryButton}"
                                Width="128"
                                Click="CloseMarkdownEditorModal_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8BB;" />
                                <TextBlock Text="Concluir" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
