                                    </StackPanel>
                                </Button>
                            </Grid>
                            <WrapPanel Orientation="Horizontal"
                                       VerticalAlignment="Center">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClientesFiltersCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <Border Style="{StaticResource ClientesFilterFieldCardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ClientesFilterLabelStyle}" Text="Status do cadastro" />
                                        <Grid Margin="0,2,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Ativos"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsClienteAtivosMode}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <controls:ThemeRockerSwitchControl x:Name="ClientesStatusRockerControl"
                                                                               Grid.Column="2"
                                                                               LeftLabel="●"
                                                                               RightLabel="○"
                                                                               ToolTip="Ativos (●) / Inativos (○)"
                                                                               IsChecked="{Binding IsClienteAtivosMode, Mode=TwoWay}" />

                                            <TextBlock Grid.Column="4"
                                                       Text="Inativos"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsClienteAtivosMode}" Value="False">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ClientesFilterFieldCardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ClientesFilterLabelStyle}" Text="Situação" />
                                        <ComboBox Style="{StaticResource ClientesCompactFilterComboStyle}"
                                                  Width="158"
                                                  ItemsSource="{Binding ClienteSituacaoFilterOptions}"
                                                  SelectedItem="{Binding ClienteSituacaoFilter, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ClientesFilterFieldCardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ClientesFilterLabelStyle}" Text="Ordenar por" />
                                        <ComboBox Style="{StaticResource ClientesCompactFilterComboStyle}"
                                                  Width="200"
                                                  ItemsSource="{Binding ClienteSortFieldOptions}"
                                                  SelectedItem="{Binding ClienteSortField, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource ClientesFilterFieldCardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ClientesFilterLabelStyle}" Text="Direção" />
                                        <ComboBox Style="{StaticResource ClientesCompactFilterComboStyle}"
                                                  Width="146"
                                                  ItemsSource="{Binding ClienteSortDirectionOptions}"
                                                  SelectedItem="{Binding ClienteSortDirection, Mode=TwoWay}" />
                                    </StackPanel>
                                </Border>

                                <Button Style="{StaticResource ClientesFilterClearButtonStyle}"
                                        VerticalAlignment="Center"
                                        Command="{Binding ResetClienteFiltersCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                                        <TextBlock Text="Limpar filtros" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <ScrollViewer Margin="0,2,0,0"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          PanningMode="HorizontalOnly">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClientesFiltersCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CanResetClienteFilters}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            <DataTrigger Binding="{Binding ClienteStatusTabIndex}" Value="1">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                <Button Command="{Binding RemoveClienteFilterCommand}"
                                        CommandParameter="status">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ClientesActiveFilterChipButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClienteStatusTabIndex}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipTextStyle}" Text="Status: Inativos" />
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipCloseStyle}" Margin="8,0,0,0" Text="&#xE711;" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding RemoveClienteFilterCommand}"
                                        CommandParameter="situacao">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ClientesActiveFilterChipButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClienteSituacaoFilter}" Value="Todos">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipTextStyle}">
                                            <Run Text="Situação: " />
                                            <Run Text="{Binding ClienteSituacaoFilter}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipCloseStyle}" Margin="8,0,0,0" Text="&#xE711;" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding RemoveClienteFilterCommand}"
                                        CommandParameter="sortfield">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ClientesActiveFilterChipButtonStyle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClienteSortField}" Value="Nome">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipTextStyle}">
                                            <Run Text="Ordenação: " />
                                            <Run Text="{Binding ClienteSortField}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipCloseStyle}" Margin="8,0,0,0" Text="&#xE711;" />
                                    </StackPanel>
                                </Button>

                                <Button Command="{Binding RemoveClienteFilterCommand}"
                                        CommandParameter="sortdirection">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource ClientesActiveFilterChipButtonStyle}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ClienteSortDirection}" Value="Decrescente">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipTextStyle}" Text="Direção: Decrescente" />
                                        <TextBlock Style="{StaticResource ClientesActiveFilterChipCloseStyle}" Margin="8,0,0,0" Text="&#xE711;" />
                                    </StackPanel>
                                </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ClientesGridCard"
                            Grid.Row="4"
                            Style="{StaticResource CardStyle}"
                            Padding="8"
                            BorderBrush="{DynamicResource BorderStrong}"
                            BorderThickness="1">
                        <Grid>
                            <Image Source="/Assets/Images/startfire.png"
                                   Width="320"
                                   Height="320"
                                   Stretch="Uniform"
                                   Opacity="0.04"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False" />
                            <DataGrid x:Name="ClientesDataGrid"
                                      Style="{StaticResource CleanDataGrid}"
                                      AutoGenerateColumns="False"
                                      CanUserSortColumns="True"
                                      IsReadOnly="True"
                                      RowHeight="36"
                                      ColumnHeaderHeight="38"
                                      FontSize="12.8"
                                      SelectionMode="Extended"
                                      SelectionUnit="FullRow"
                                      RowStyle="{StaticResource ClienteRowStyle}"
                                      ColumnHeaderStyle="{StaticResource UnifiedGridHeaderStyle}"
                                      ItemsSource="{Binding Clientes}"
                                      SelectedItem="{Binding SelectedCliente, Mode=TwoWay}"
                                      PreviewMouseLeftButtonDown="ClientesDataGrid_PreviewMouseLeftButtonDown"
                                      SelectionChanged="ClientesDataGrid_SelectionChanged"
                                      Sorting="ClientesDataGrid_Sorting"
                                      MouseDoubleClick="ClientesDataGrid_MouseDoubleClick">
                                <DataGrid.Resources>
                                    <Style x:Key="ClientesSortableHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource UnifiedGridHeaderStyle}">
                                        <Setter Property="ToolTip" Value="Clique para ordenar" />
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="44" CanUserSort="False">
                                        <DataGridTemplateColumn.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="&#x2713;"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextMuted}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.HeaderTemplate>
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox Style="{StaticResource RowSelectionCheckBoxStyle}"
                                                          PreviewMouseLeftButtonDown="ClientesSelectionCheckBox_PreviewMouseLeftButtonDown"
                                                          IsChecked="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Nome" Binding="{Binding NomeFantasia}" SortMemberPath="NomeFantasia" HeaderStyle="{StaticResource ClientesSortableHeaderStyle}" Width="2*" ElementStyle="{StaticResource LeftCellStyle}" />
                                    <DataGridTextColumn Header="CPF/CNPJ" Binding="{Binding CPF}" SortMemberPath="CPF" HeaderStyle="{StaticResource ClientesSortableHeaderStyle}" Width="*" ElementStyle="{StaticResource LeftCellStyle}" />
                                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone1}" SortMemberPath="Telefone1" HeaderStyle="{StaticResource ClientesSortableHeaderStyle}" Width="*" ElementStyle="{StaticResource LeftCellStyle}" />
                                    <DataGridTextColumn Header="Cidade" Binding="{Binding Cidade}" SortMemberPath="Cidade" HeaderStyle="{StaticResource ClientesSortableHeaderStyle}" Width="*" ElementStyle="{StaticResource LeftCellStyle}" />
                                    <DataGridTextColumn Header="Vencimento Extintores" Binding="{Binding VencimentoExtintores, StringFormat=dd/MM/yyyy}" SortMemberPath="VencimentoExtintores" HeaderStyle="{StaticResource ClientesSortableHeaderStyle}" Width="*" ElementStyle="{StaticResource CenterCellStyle}" />
                                    <DataGridTemplateColumn Header="Situação" SortMemberPath="SituacaoTexto" HeaderStyle="{StaticResource ClientesSortableHeaderStyle}" Width="160">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource StatusBadgeBorderStyle}" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource StatusBadgeTextStyle}" Text="{Binding SituacaoTexto}" />
                                                </Border>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <Border Background="{DynamicResource SurfaceBackground}"
                                    CornerRadius="10"
                                    Margin="8"
                                    Padding="18"
                                    Visibility="{Binding ShowClientesLoadingState, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE895;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" />
                                    <TextBlock Text="{Binding ClientesStateTitle}"
                                               Margin="0,10,0,0"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="{Binding ClientesStateDescription}"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>
                            </Border>
                            <Border Background="{DynamicResource CardBackground}"
                                    CornerRadius="10"
                                    Margin="8"
                                    Padding="18"
                                    Visibility="{Binding ShowClientesEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                                    IsHitTestVisible="False">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE8A5;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="22"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}" />
                                    <TextBlock Text="{Binding ClientesStateTitle}"
                                               Margin="0,10,0,0"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="{Binding ClientesStateDescription}"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               MaxWidth="420" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="5" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding FooterSummary}"
                                    VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource TextSecondary}" />

                        <Border Grid.Column="1"
                                Style="{StaticResource ClientesPaginationBarStyle}"
                                Visibility="{Binding ShowPagination, Converter={StaticResource BoolToVisibilityConverter}}">
                            <WrapPanel Orientation="Horizontal"
                                       VerticalAlignment="Center">
                                <Button Style="{StaticResource ClientesPaginationNavButtonStyle}"
                                        Command="{Binding PreviousPageCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE76B;" />
                                        <TextBlock Text="Anterior" />
                                    </StackPanel>
                                </Button>

                                <ItemsControl ItemsSource="{Binding PageIndexes}" Margin="0,0,2,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ClientesPaginationPageButtonStyle}"
                                                    Tag="{Binding}"
                                                    Command="{Binding DataContext.GoToPageCommand, RelativeSource={RelativeSource AncestorType=TabControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding}" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Style="{StaticResource ClientesPaginationCurrentBadgeStyle}">
                                    <TextBlock Text="{Binding PageNumber, StringFormat=Página {0}}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBlueFg}" />
                                </Border>

                                <Button Style="{StaticResource ClientesPaginationNavButtonStyle}"
                                        Margin="0"
                                        Command="{Binding NextPageCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Text="Próximo" />
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Margin="8,0,0,0" Text="&#xE76C;" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Pagamentos">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Pagamentos"
                                       Style="{StaticResource PageTitleText}" />
                            <TextBlock Text="Acompanhamento de cobranças e vencimentos"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource SubTitleText}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                MinWidth="112"
                                Height="38"
                                VerticalAlignment="Top"
                                Click="HelpButton_Click"
                                Tag="Pagamentos">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE897;" />
                                <TextBlock Text="Ajuda" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border x:Name="PagamentosActionBar" Grid.Row="1" Style="{StaticResource ActionBar}" Margin="0,10,0,16">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <WrapPanel Grid.Column="0"
                                       Orientation="Horizontal"
                                       VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource ShortcutHintTextStyle}" Text="Atalhos: Ctrl+N / Ctrl+F" />
                                <Button x:Name="NewPagamentoButton" Style="{StaticResource ActionBarPrimaryButtonStyle}" Margin="0,0,12,0" MinWidth="170" Command="{Binding NewPagamentoCommand}" ToolTip="Novo pagamento (Ctrl+N)">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE710;" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                        <TextBlock Text="Novo Pagamento" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionBarSecondaryButtonStyle}" Margin="0,0,12,0" MinWidth="110" Command="{Binding EditPagamentoCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE70F;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <TextBlock Text="Editar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionBarSecondaryButtonStyle}" Margin="0,0,12,0" MinWidth="132" Command="{Binding CobrancaCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8BD;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <TextBlock Text="Cobrança" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionBarDangerButtonStyle}" Margin="0,0,12,0" Command="{Binding DeletePagamentoCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74D;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <TextBlock Text="Excluir" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>

                            <Border Grid.Column="1"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="8,0,12,0"
                                    Style="{StaticResource SelectedClientsBadgeStyle}">
                                <TextBlock Text="{Binding SelectedPagamentosSummary}"
                                           Style="{StaticResource SelectedClientsBadgeTextStyle}" />
                            </Border>

                            <Border Grid.Column="2"
                                    Style="{StaticResource ActionBarDivider}"
                                    VerticalAlignment="Center"
                                    Margin="2,0,12,0" />

                            <Button Grid.Column="3"
                                    Style="{StaticResource ActionBarImportButtonStyle}"
                                    Margin="0"
                                    MinWidth="146"
                                    VerticalAlignment="Center"
                                    Command="{Binding ImportPagamentosCommand}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8B5;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Importar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Border x:Name="PagamentosSearchCard"
                            Grid.Row="2"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,0,10"
                            Padding="14,10"
                            BorderBrush="{DynamicResource BorderStrong}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Buscar pagamentos"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="PagamentosSearchTextBox"
                                     Grid.Column="2"
                                     Style="{StaticResource SearchTextBox}"
                                     Text="{Binding PagamentoSearchTerm, UpdateSourceTrigger=PropertyChanged}"
                                     Height="36"
                                     Tag="Cliente, descrição ou CPF/CNPJ" />
                            <Button Grid.Column="4"
                                    Style="{StaticResource SecondaryButton}"
                                    MinWidth="112"
                                    Height="36"
                                    Command="{Binding SearchPagamentosCommand}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE721;" />
                                    <TextBlock Text="Buscar" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Border x:Name="PagamentosFiltersCard"
                            Grid.Row="3"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,0,10"
                            Padding="10,7"
                            BorderBrush="{DynamicResource BorderStrong}"
                            BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="2,0,2,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Filtros avançados"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary}" />
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="0"
                                        Height="30"
                                        Padding="10,0"
                                        Command="{Binding TogglePagamentosFiltersCollapsedCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE70D;" />
                                        <TextBlock Text="{Binding PagamentosFiltersToggleText}" />
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <WrapPanel Orientation="Horizontal"
                                       VerticalAlignment="Center">
                                <WrapPanel.Style>
                                    <Style TargetType="WrapPanel">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPagamentosFiltersCollapsed}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </WrapPanel.Style>
                                <Border Style="{StaticResource ClientesFilterFieldCardStyle}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource ClientesFilterLabelStyle}" Text="Situação" />
                                        <ComboBox Style="{StaticResource ClientesCompactFilterComboStyle}"
                                                  Width="168"
                                                  SelectedValuePath="Content"
                                                  SelectedValue="{Binding PagamentoFilter}">
                                            <ComboBoxItem Content="Todos" />
                                            <ComboBoxItem Content="Em aberto" />
                                            <ComboBoxItem Content="Pago" />
                                        </ComboBox>
                                    </StackPanel>
                                </Border>

                                <Button Style="{StaticResource ClientesFilterClearButtonStyle}"
                                        VerticalAlignment="Center"
                                        Command="{Binding ResetPagamentoFiltersCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                                        <TextBlock Text="Limpar filtros" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

