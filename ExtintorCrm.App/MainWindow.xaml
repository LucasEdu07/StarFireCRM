<Window x:Class="ExtintorCrm.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ExtintorCrm.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Star Fire CRM - Gestão de Clientes"
        Height="{Binding MainWindowHeight, Mode=OneWay}"
        Width="{Binding MainWindowWidth, Mode=OneWay}"
        Left="{Binding MainWindowLeft, Mode=OneWay}"
        Top="{Binding MainWindowTop, Mode=OneWay}"
        ResizeMode="CanMinimize"
        WindowState="{Binding MainWindowState, Mode=OneWay}"
        WindowStyle="None"
        Topmost="{Binding MainTopmost, Mode=OneWay}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontFamily="Segoe UI Variable"
        FontSize="14">
    <Window.Resources>
        <ResourceDictionary>
            <local:DashboardKpiItemWidthConverter x:Key="DashboardKpiItemWidthConverter" />
            <local:ValuesEqualMultiConverter x:Key="ValuesEqualMultiConverter" />
            <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencendo">
                        <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencendo">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Padding" Value="18" />
                <Setter Property="Margin" Value="0,0,16,16" />
            </Style>

            <CollectionViewSource x:Key="GroupedCriticalAlertsTop" Source="{Binding CriticalAlertsTop}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Tipo" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <CollectionViewSource x:Key="GroupedCriticalAlertsAll" Source="{Binding CriticalAlertsAll}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Tipo" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <Style x:Key="KpiCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="Margin" Value="0,0,16,16" />
            </Style>

            <Style x:Key="DashboardAnimatedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.992" ScaleY="0.992" />
                            <TranslateTransform Y="12" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryRedHover}" />
                        <Setter Property="Effect" Value="{StaticResource SoftShadowHover}" />
                    </Trigger>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 From="12"
                                                 To="0"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 From="0.992"
                                                 To="1"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 From="0.992"
                                                 To="1"
                                                 Duration="0:0:0.24" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 To="-4"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.01"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.01"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DashboardAnimatedKpiCardStyle" TargetType="Border" BasedOn="{StaticResource KpiCardStyle}">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="Height" Value="168" />
                <Setter Property="MinHeight" Value="168" />
                <Setter Property="Padding" Value="12,10,12,10" />
                <Setter Property="CornerRadius" Value="15" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.992" ScaleY="0.992" />
                            <TranslateTransform Y="10" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                        <Setter Property="Effect" Value="{StaticResource SoftShadowHover}" />
                    </Trigger>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.22" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 From="10"
                                                 To="0"
                                                 Duration="0:0:0.22" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 From="0.992"
                                                 To="1"
                                                 Duration="0:0:0.22" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 From="0.992"
                                                 To="1"
                                                 Duration="0:0:0.22" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 To="-4"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.008"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.008"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="KpiCardDangerStyle" TargetType="Border" BasedOn="{StaticResource DashboardAnimatedKpiCardStyle}">
                <Setter Property="BorderBrush" Value="{DynamicResource DangerBorder}" />
                <Setter Property="Background" Value="{DynamicResource KpiDangerCardBackground}" />
            </Style>

            <Style x:Key="KpiCardWarningStyle" TargetType="Border" BasedOn="{StaticResource DashboardAnimatedKpiCardStyle}">
                <Setter Property="BorderBrush" Value="{DynamicResource Warning}" />
                <Setter Property="Background" Value="{DynamicResource KpiWarningCardBackground}" />
            </Style>

            <Style x:Key="KpiIconWrapStyle" TargetType="Border">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="40" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="KpiValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="29" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                <Setter Property="Margin" Value="0,6,0,1" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="MinHeight" Value="31" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="LineHeight" Value="31" />
            </Style>

            <Style x:Key="KpiLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="LineHeight" Value="15" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="MinHeight" Value="15" />
            </Style>

            <Style x:Key="KpiBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="KpiSeverityBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgePill}">
                <Setter Property="MinWidth" Value="70" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="0,2,0,0" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
            </Style>

            <Style x:Key="KpiTopStripBaseStyle" TargetType="Border">
                <Setter Property="Height" Value="3" />
                <Setter Property="CornerRadius" Value="15,15,0,0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="Opacity" Value="0.95" />
            </Style>

            <Style x:Key="KpiOrbStyle" TargetType="Border">
                <Setter Property="Width" Value="72" />
                <Setter Property="Height" Value="72" />
                <Setter Property="CornerRadius" Value="36" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Margin" Value="0,-20,-20,0" />
                <Setter Property="Opacity" Value="0.75" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                        <Setter Property="Opacity" Value="0.95" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.08" ScaleY="1.08" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="KpiHoverSheenStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Margin" Value="1" />
                <Setter Property="Opacity" Value="0" />
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00FFFFFF" Offset="0" />
                            <GradientStop Color="#22FFFFFF" Offset="0.52" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                        <Setter Property="Opacity" Value="1" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.012" ScaleY="1.012" />
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="KpiMetaRowStyle" TargetType="DockPanel">
                <Setter Property="LastChildFill" Value="False" />
                <Setter Property="Margin" Value="0,5,0,0" />
                <Setter Property="Opacity" Value="0.88" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                        <Setter Property="Opacity" Value="1" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="KpiMetaTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="KpiMetaGlyphStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="10.5" />
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="KpiTopStripDangerStyle" TargetType="Border" BasedOn="{StaticResource KpiTopStripBaseStyle}">
                <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
            </Style>

            <Style x:Key="KpiTopStripWarningStyle" TargetType="Border" BasedOn="{StaticResource KpiTopStripBaseStyle}">
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
            </Style>

            <Style x:Key="AlertStripStyle" TargetType="Border">
                <Setter Property="Width" Value="5" />
                <Setter Property="CornerRadius" Value="8,0,0,8" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Nivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Nivel}" Value="OK">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="AlertDayBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Nivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Nivel}" Value="OK">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="UnifiedGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Setter Property="Padding" Value="2" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowHoverBackground}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowSelectedBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource RowSelectedBorder}" />
                        <Setter Property="BorderThickness" Value="3,1,1,1" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="UnifiedGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
            </Style>

            <Style x:Key="PagamentoRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource UnifiedGridRowStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowSelectedBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource RowSelectedBorder}" />
                        <Setter Property="BorderThickness" Value="3,1,1,1" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GridTextCellBaseStyle" TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            </Style>

            <Style x:Key="LeftCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextCellBaseStyle}">
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="MoneyCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextCellBaseStyle}">
                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,8,0" />
            </Style>

            <Style x:Key="CenterCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextCellBaseStyle}">
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ToolbarIconStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonGlyphIconStyle}">
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Style>

            <Style x:Key="PagoBadgeStyle" TargetType="Border">
                <Setter Property="MinWidth" Value="94" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Pago}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PagoBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Text" Value="Aberto" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Pago}" Value="True">
                        <Setter Property="Text" Value="Pago" />
                        <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CriticalGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource UnifiedGridRowStyle}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="ToolTip" Value="Abrir perfil do cliente" />
                <Setter Property="MinHeight" Value="44" />
            </Style>

            <Style x:Key="CriticalClienteTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Margin" Value="6,0,8,0" />
            </Style>

            <Style x:Key="CriticalTypeBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
