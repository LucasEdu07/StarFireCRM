                                <Button Style="{StaticResource ClientesPaginationNavButtonStyle}"
                                        Margin="0"
                                        Command="{Binding NextPageCommand}">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Text="Próximo" />
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Margin="8,0,0,0" Text="&#xE76C;" />
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Border>
