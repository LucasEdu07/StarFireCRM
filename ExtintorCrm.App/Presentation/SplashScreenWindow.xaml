<Window x:Class="ExtintorCrm.App.Presentation.SplashScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Star Fire CRM"
        Width="620"
        Height="350"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Opacity="0">
    <Window.Resources>
        <GeometryGroup x:Key="SplashExtinguisherIconGeometry">
            <PathGeometry Figures="M13,16 H23 A3,3 0 0 1 26,19 V38 A4,4 0 0 1 22,42 H14 A4,4 0 0 1 10,38 V19 A3,3 0 0 1 13,16 Z" />
            <PathGeometry Figures="M15.2,12 H20.8 V16 H15.2 Z" />
            <PathGeometry Figures="M15.5,10.4 C15.5,9.1 16.6,8 17.9,8 H21 C22.3,8 23.4,9.1 23.4,10.4" />
            <PathGeometry Figures="M23.2,18 C30.5,18 33.5,21.2 33.5,26" />
            <PathGeometry Figures="M33.5,26 H37" />
            <PathGeometry Figures="M16,33 H20" />
        </GeometryGroup>

        <DrawingBrush x:Key="SplashExtinguisherPattern"
                      TileMode="Tile"
                      Viewport="0,0,96,96"
                      ViewportUnits="Absolute"
                      Viewbox="0,0,96,96"
                      ViewboxUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="1.02" ScaleY="1.02" />
                                <TranslateTransform X="10" Y="10" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Geometry="{StaticResource SplashExtinguisherIconGeometry}">
                            <GeometryDrawing.Pen>
                                <Pen Brush="{DynamicResource SplashPatternStroke}"
                                     Thickness="1.25"
                                     StartLineCap="Round"
                                     EndLineCap="Round"
                                     LineJoin="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="0.68" ScaleY="0.68" />
                                <TranslateTransform X="58" Y="53" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Geometry="{StaticResource SplashExtinguisherIconGeometry}">
                            <GeometryDrawing.Pen>
                                <Pen Brush="{DynamicResource SplashPatternStrokeSoft}"
                                     Thickness="1.15"
                                     StartLineCap="Round"
                                     EndLineCap="Round"
                                     LineJoin="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <DrawingBrush x:Key="SplashExtinguisherPatternOffset"
                      TileMode="Tile"
                      Viewport="0,0,96,96"
                      ViewportUnits="Absolute"
                      Viewbox="0,0,96,96"
                      ViewboxUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="0.58" ScaleY="0.58" />
                                <TranslateTransform X="48" Y="10" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Geometry="{StaticResource SplashExtinguisherIconGeometry}">
                            <GeometryDrawing.Pen>
                                <Pen Brush="{DynamicResource SplashPatternStrokeSoft}"
                                     Thickness="1.05"
                                     StartLineCap="Round"
                                     EndLineCap="Round"
                                     LineJoin="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                    <DrawingGroup>
                        <DrawingGroup.Transform>
                            <TransformGroup>
                                <ScaleTransform ScaleX="0.5" ScaleY="0.5" />
                                <TranslateTransform X="8" Y="58" />
                            </TransformGroup>
                        </DrawingGroup.Transform>
                        <GeometryDrawing Geometry="{StaticResource SplashExtinguisherIconGeometry}">
                            <GeometryDrawing.Pen>
                                <Pen Brush="{DynamicResource SplashPatternStroke}"
                                     Thickness="1.0"
                                     StartLineCap="Round"
                                     EndLineCap="Round"
                                     LineJoin="Round" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.22" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="20"
            BorderBrush="{DynamicResource SplashShellBorder}"
            BorderThickness="1">
        <Border.Background>
            <DynamicResource ResourceKey="SplashShellBackground" />
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="{DynamicResource ShadowColor}"
                              BlurRadius="26"
                              ShadowDepth="2"
                              Opacity="0.26" />
        </Border.Effect>

        <Grid>
            <Border Margin="1"
                    CornerRadius="19"
                    BorderBrush="{DynamicResource SplashInnerBorder}"
                    BorderThickness="1" />

            <Border Margin="1"
                    CornerRadius="19"
                    IsHitTestVisible="False">
                <Border.Background>
                    <DynamicResource ResourceKey="SplashSheenOverlay" />
                </Border.Background>
            </Border>

            <Border Margin="1"
                    CornerRadius="19"
                    IsHitTestVisible="False"
                    Opacity="0.24">
                <Border.Background>
                    <StaticResource ResourceKey="SplashExtinguisherPattern" />
                </Border.Background>
            </Border>

            <Border Margin="1"
                    CornerRadius="19"
                    IsHitTestVisible="False"
                    Opacity="0.15">
                <Border.Background>
                    <StaticResource ResourceKey="SplashExtinguisherPatternOffset" />
                </Border.Background>
            </Border>

            <Grid Margin="34,26,34,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Ellipse Width="220"
                             Height="220"
                             Fill="{DynamicResource SplashOrbPrimary}"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-120,-110,0" />
                    <Ellipse Width="180"
                             Height="180"
                             Fill="{DynamicResource SplashOrbSecondary}"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Bottom"
                             Margin="-90,0,0,-96" />

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border Background="{DynamicResource SplashLogoCardBackground}"
                                BorderBrush="{DynamicResource SplashLogoCardBorder}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12">
                            <Image Width="172"
                                   Height="70"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   Source="/ExtintorCrm.App;component/Assets/Images/startfire.png" />
                        </Border>

                        <TextBlock Text="Carregando sistema"
                                   Margin="0,18,0,0"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SplashTitleForeground}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1">
                    <ProgressBar IsIndeterminate="True"
                                 Height="7"
                                 Minimum="0"
                                 Maximum="100"
                                 Foreground="{DynamicResource SplashProgressForeground}"
                                 Background="{DynamicResource SplashProgressTrack}"
                                 BorderThickness="0"
                                 Margin="0,0,0,10" />
                    <TextBlock x:Name="StatusText"
                               Text="Inicializando..."
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource SplashStatusForeground}"
                               FontSize="13" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
