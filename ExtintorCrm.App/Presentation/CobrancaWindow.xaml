<Window x:Class="ExtintorCrm.App.Presentation.CobrancaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobrança Inteligente"
        Width="620"
        Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.18" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cobrança Inteligente"
                           Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="Cancel_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Border Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding ClienteNome}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding ContatoInfo}" Margin="0,6,0,0" Foreground="{DynamicResource TextSecondary}" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,12,0,10"
                            Padding="10,8"
                            CornerRadius="10"
                            Background="{DynamicResource SurfaceMuted}"
                            BorderBrush="{DynamicResource ControlBorder}"
                            BorderThickness="1">
                        <TextBlock Text="Revise e edite a mensagem abaixo antes de escolher o canal de envio."
                                   Foreground="{DynamicResource TextSecondary}" />
                    </Border>

                    <TextBox Grid.Row="2"
                             Style="{StaticResource ModernTextBox}"
                             Text="{Binding Mensagem, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="False"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             MinHeight="230" />

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0">
                        <Button Style="{StaticResource SecondaryButton}"
                                MinWidth="104"
                                Margin="0,0,8,0"
                                Click="Copy_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                           Text="&#xE8C8;" />
                                <TextBlock Text="Copiar" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource AccentButton}"
                                MinWidth="114"
                                Margin="0,0,8,0"
                                Click="Email_Click"
                                IsEnabled="{Binding CanSendEmail}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                           Text="&#xE715;"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <TextBlock Text="E-mail" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource PrimaryButton}"
                                MinWidth="126"
                                Margin="0,0,8,0"
                                Click="WhatsApp_Click"
                                IsEnabled="{Binding CanSendWhatsApp}">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                           Text="&#xE8BD;"
                                           Foreground="{DynamicResource ButtonPrimaryFg}" />
                                <TextBlock Text="WhatsApp" Foreground="{DynamicResource ButtonPrimaryFg}" />
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource SecondaryButton}"
                                MinWidth="96"
                                Click="Cancel_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                           Text="&#xE711;" />
                                <TextBlock Text="Fechar" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

