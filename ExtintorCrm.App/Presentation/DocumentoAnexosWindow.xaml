<Window x:Class="ExtintorCrm.App.Presentation.DocumentoAnexosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Anexos"
        Height="560"
        Width="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0"
        Loaded="Window_Loaded">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.24"
                                     EasingFunction="{StaticResource DialogEaseOut}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Title}"
                           Style="{StaticResource DialogTitleTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding Title}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" />
                <TextBlock Text="{Binding Subtitle}"
                           Margin="0,4,0,0"
                           Foreground="{DynamicResource TextSecondary}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource DialogAnimatedCardStyle}"
                    Margin="0,0,0,10"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="190" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="10" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Tipo do documento"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold" />
                    <ComboBox Grid.Column="2"
                              Style="{StaticResource ModernComboBox}"
                              Height="36"
                              ItemsSource="{Binding TipoDocumentoOptions}"
                              SelectedItem="{Binding SelectedTipoDocumento, Mode=TwoWay}" />

                    <TextBlock Grid.Column="4"
                               Text="{Binding TotalAnexos, StringFormat=Total: {0}}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="4,0,0,0" />

                    <Button Grid.Column="6"
                            Style="{StaticResource AccentButton}"
                            MinWidth="118"
                            Height="36"
                            Command="{Binding AddCommand}">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconAttachmentGeometry}" />
                            <TextBlock Text="Anexar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="8"
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="102"
                            Height="36"
                            Command="{Binding OpenCommand}">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"  Style="{StaticResource ToolbarVectorIconDangerStyle}" Data="{StaticResource IconOpenExternalGeometry}" />
                            <TextBlock Text="Abrir" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="10"
                            Style="{StaticResource DangerButton}"
                            MinWidth="102"
                            Height="36"
                            Command="{Binding RemoveCommand}">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconTrashGeometry}" />
                            <TextBlock Text="Excluir" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource DialogAnimatedCardStyle}"
                    Padding="8">
                <DataGrid Style="{StaticResource CleanDataGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          RowHeight="52"
                          ColumnHeaderHeight="40"
                          FontSize="12.8"
                          ItemsSource="{Binding Anexos}"
                          SelectedItem="{Binding SelectedAnexo, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Arquivo" Width="3.2*" CellTemplate="{StaticResource AttachmentExplorerFileTemplate}" />
                        <DataGridTextColumn Header="Tamanho" Binding="{Binding TamanhoTexto}" Width="120" />
                        <DataGridTextColumn Header="Criado em" Binding="{Binding CriadoEmTexto}" Width="170" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Style="{StaticResource SecondaryButton}"
                        Width="130"
                        IsCancel="True">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCloseGeometry}" />
                        <TextBlock Text="Fechar" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>



