                                    Style="{StaticResource ActionBarImportButtonStyle}"
                                    Margin="0"
                                    MinWidth="146"
                                    VerticalAlignment="Center"
                                    Command="{Binding ImportPagamentosCommand}">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8B5;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    <TextBlock Text="Importar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </StackPanel>
