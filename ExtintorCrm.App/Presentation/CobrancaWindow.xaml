<Window x:Class="ExtintorCrm.App.Presentation.CobrancaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobrança Inteligente"
        Width="1120"
        Height="700"
        MinWidth="1020"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Closing="Window_Closing"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.24"
                                     EasingFunction="{StaticResource DialogEaseOut}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource DialogSurfaceCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="SidebarCard" TargetType="Border" BasedOn="{StaticResource SectionCard}">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MessageQualityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMessageEmpty}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource DangerFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMessageTooShort}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Warning}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsMessageTooLong}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource Warning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CopyFeedbackTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Info}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasCopyFeedback}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChannelChipStyle" TargetType="Border" BasedOn="{StaticResource BadgePill}">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
        </Style>

        <Style x:Key="HistoryCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCard}">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="HistoryTimelineDotStyle" TargetType="Border">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Background" Value="{DynamicResource AccentBlueBorder}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardBackground}" />
            <Setter Property="BorderThickness" Value="2" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Canal}" Value="WhatsApp">
                    <Setter Property="Background" Value="{DynamicResource Success}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="E-mail">
                    <Setter Property="Background" Value="{DynamicResource ActionAccentBg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="Registro manual">
                    <Setter Property="Background" Value="{DynamicResource BadgeMutedFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="Copia">
                    <Setter Property="Background" Value="{DynamicResource Warning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HistoryMetaTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HistoryChannelBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgePill}">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource BadgeMutedBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Canal}" Value="WhatsApp">
                    <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Success}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="E-mail">
                    <Setter Property="Background" Value="{DynamicResource AccentBlueBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="Copia">
                    <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource Warning}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HistoryChannelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BadgeMutedFg}" />
            <Setter Property="FontSize" Value="11.4" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Canal}" Value="WhatsApp">
                    <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="E-mail">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBlueFg}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Canal}" Value="Copia">
                    <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HistoryTagBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="7" />
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="HistoryTagTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="11.2" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="HistoryMessageTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="19" />
        </Style>

        <Style x:Key="FeaturePreviewBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgePill}">
            <Setter Property="Padding" Value="7,2" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Warning}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="FeaturePreviewBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource SurfaceBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cobran&#xE7;a Inteligente"
                           Style="{StaticResource DialogTitleTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="Cancel_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18,14,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="310" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SidebarCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Conversas"
                                       FontSize="16.5"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Painel de cobran&#xE7;a por cliente"
                                       Margin="0,3,0,0"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12.5" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,12,0,12"
                                Padding="10"
                                CornerRadius="10"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                Background="{DynamicResource ControlBackground}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Path Width="16"
                                      Height="16"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"
                                      Style="{StaticResource ToolbarVectorIconStyle}"
                                      Data="{StaticResource IconSearchGeometry}" />
                                <TextBlock Grid.Column="1"
                                           Text="Contato atual"
                                           Foreground="{DynamicResource TextSecondary}"
                                           VerticalAlignment="Center"
                                           FontSize="12.5" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="2"
                                Padding="12"
                                Margin="0,0,0,12"
                                CornerRadius="12"
                                Background="{DynamicResource CardBackground}"
                                BorderBrush="{DynamicResource AccentBlueBorder}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40"
                                        Height="40"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        CornerRadius="20"
                                        Background="{DynamicResource BadgeSuccessBg}"
                                        BorderBrush="{DynamicResource Success}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding ClienteInitials}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{DynamicResource BadgeSuccessFg}" />
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding ClienteNome}"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ContatoInfo}"
                                               Margin="0,2,0,0"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding PrazoResumo, StringFormat=Status: {0}}"
                                               Margin="0,5,0,0"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="11.5"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="3">
                            <Border Style="{StaticResource SectionCard}" Padding="12" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Resumo da cobran&#xE7;a"
                                               FontSize="14.6"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Valor" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding ValorResumo}" Margin="0,2,0,6" />
                                    <TextBlock Text="Vencimento" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding VencimentoResumo}" Margin="0,2,0,6" />
                                    <TextBlock Text="Prazo" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding PrazoResumo}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SectionCard}" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="Estrat&#xE9;gia"
                                               FontSize="14.6"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />
                                    <TextBlock Text="Etapa da r&#xE9;gua" Style="{StaticResource SectionLabel}" />
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              Height="37"
                                              Margin="0,2,0,8"
                                              ItemsSource="{Binding EtapaOptions}"
                                              SelectedItem="{Binding EtapaSelecionada}" />

                                    <TextBlock Text="Tom da mensagem" Style="{StaticResource SectionLabel}" />
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              Height="37"
                                              Margin="0,2,0,10"
                                              ItemsSource="{Binding TomOptions}"
                                              SelectedItem="{Binding TomSelecionado}" />

                                    <Button Style="{StaticResource SecondaryButton}"
                                            MinWidth="148"
                                            Height="34"
                                            HorizontalAlignment="Left"
                                            Click="ApplyTemplate_Click">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconSparkleGeometry}" />
                                            <TextBlock Text="Aplicar sugest&#xE3;o" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="4"
                                Margin="0,12,0,0"
                                Padding="10"
                                CornerRadius="10"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                Background="{DynamicResource CardBackground}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource MessageQualityTextStyle}" Text="{Binding MessageQualityHint}" />
                                <TextBlock Margin="0,5,0,0"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="11.5"
                                           Text="{Binding MessageLength, StringFormat=Caracteres: {0}}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource SectionCard}"
                        Padding="0"
                        Background="{DynamicResource CardBackground}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Padding="14,12"
                                CornerRadius="14,14,0,0"
                                Background="{DynamicResource SurfaceMuted}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Width="42"
                                        Height="42"
                                        CornerRadius="21"
                                        Background="{DynamicResource BadgeSuccessBg}"
                                        BorderBrush="{DynamicResource Success}"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding ClienteInitials}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="{DynamicResource BadgeSuccessFg}" />
                                </Border>

                                <StackPanel Grid.Column="1" Margin="10,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding ClienteNome}"
                                               FontWeight="SemiBold"
                                               FontSize="15.5"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding ContatoInfo}"
                                               Margin="0,2,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right">
                                    <Border Style="{StaticResource ChannelChipStyle}"
                                            Visibility="{Binding CanSendEmail, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconMailGeometry}" />
                                            <TextBlock Text="E-mail" Margin="6,0,0,0" FontSize="11.5" />
                                        </StackPanel>
                                    </Border>
                                    <Border Style="{StaticResource ChannelChipStyle}"
                                            Margin="0"
                                            Visibility="{Binding CanSendWhatsApp, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconPhoneGeometry}" />
                                            <TextBlock Text="WhatsApp" Margin="6,0,0,0" FontSize="11.5" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ScrollViewer Grid.Row="0"
                                          Padding="14,12"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <Border Padding="10,8"
                                            Margin="0,0,0,12"
                                            CornerRadius="10"
                                            Background="{DynamicResource SurfaceMuted}"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1">
                                        <TextBlock Text="Revise a mensagem antes de enviar. Toda intera&#xE7;&#xE3;o registrada aqui melhora o hist&#xF3;rico de cobran&#xE7;a."
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="12.5"
                                                   TextWrapping="Wrap" />
                                    </Border>

                                    <DockPanel LastChildFill="False" Margin="0,0,0,10">
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    DockPanel.Dock="Left">
                                            <Path Width="14"
                                                  Height="14"
                                                  Margin="0,0,6,0"
                                                  Style="{StaticResource ToolbarVectorIconStyle}"
                                                  Data="{StaticResource IconListGeometry}" />
                                            <TextBlock Text="Hist&#xF3;rico de cobran&#xE7;as"
                                                       FontSize="12.8"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                        <Border DockPanel.Dock="Right"
                                                Style="{StaticResource BadgePill}"
                                                Padding="8,3"
                                                Background="{DynamicResource SurfaceMuted}">
                                            <TextBlock Text="{Binding HistoricoItens.Count, StringFormat={}{0} registros}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11.3"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DockPanel>

                                    <Border Margin="0,0,0,10"
                                            Padding="10,8"
                                            CornerRadius="10"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource ControlBorder}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasHistorico}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="15"
                                                  Height="15"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Style="{StaticResource ToolbarVectorIconStyle}"
                                                  Data="{StaticResource IconInfoGeometry}" />
                                            <TextBlock Text="Ainda n&#xE3;o h&#xE1; registros de intera&#xE7;&#xE3;o para esta cobran&#xE7;a."
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding HistoricoItens}">
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasHistorico}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Column="0">
                                                        <Border Width="2"
                                                                Margin="0,24,0,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Stretch"
                                                                Background="{DynamicResource ControlBorder}" />
                                                        <Border Margin="0,8,0,0"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Top"
                                                                Style="{StaticResource HistoryTimelineDotStyle}" />
                                                    </Grid>

                                                    <Border Grid.Column="1"
                                                            MaxWidth="560"
                                                            HorizontalAlignment="Left"
                                                            Style="{StaticResource HistoryCardStyle}">
                                                        <StackPanel>
                                                            <DockPanel LastChildFill="False">
                                                                <TextBlock DockPanel.Dock="Left"
                                                                           Text="{Binding TimestampLabel}"
                                                                           Style="{StaticResource HistoryMetaTextStyle}" />
                                                                <Border DockPanel.Dock="Right"
                                                                        Style="{StaticResource HistoryChannelBadgeStyle}">
                                                                    <TextBlock Text="{Binding CanalLabel}"
                                                                               Style="{StaticResource HistoryChannelTextStyle}" />
                                                                </Border>
                                                            </DockPanel>

                                                            <StackPanel Margin="0,7,0,0" Orientation="Horizontal">
                                                                <Border Style="{StaticResource HistoryTagBadgeStyle}">
                                                                    <TextBlock Text="{Binding EtapaLabel}"
                                                                               Style="{StaticResource HistoryTagTextStyle}" />
                                                                </Border>
                                                                <Border Margin="6,0,0,0"
                                                                        Style="{StaticResource HistoryTagBadgeStyle}">
                                                                    <TextBlock Text="{Binding TomLabel}"
                                                                               Style="{StaticResource HistoryTagTextStyle}" />
                                                                </Border>
                                                            </StackPanel>

                                                            <TextBlock Margin="0,8,0,0"
                                                                       Text="{Binding MensagemLabel}"
                                                                       Style="{StaticResource HistoryMessageTextStyle}" />
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border Padding="12,10"
                                            Margin="0,6,0,2"
                                            MaxWidth="540"
                                            HorizontalAlignment="Right"
                                            CornerRadius="12"
                                            Background="{DynamicResource BadgeSuccessBg}"
                                            BorderBrush="{DynamicResource Success}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMessageEmpty}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="Rascunho da mensagem"
                                                       FontWeight="SemiBold"
                                                       FontSize="11.5"
                                                       Foreground="{DynamicResource BadgeSuccessFg}" />
                                            <TextBlock Text="{Binding Mensagem}"
                                                       Margin="0,4,0,0"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource BadgeSuccessFg}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>

                            <Border Grid.Row="1"
                                    Margin="14,0,14,14"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceMuted}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <DockPanel LastChildFill="False">
                                        <TextBlock Style="{StaticResource SectionLabel}" Text="Mensagem de cobran&#xE7;a" DockPanel.Dock="Left" />
                                        <TextBlock DockPanel.Dock="Right"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="11.5"
                                                   Text="{Binding MessageLength, StringFormat=Caracteres: {0}}" />
                                    </DockPanel>

                                    <TextBox Grid.Row="1"
                                             Margin="0,8,0,0"
                                             MinHeight="108"
                                             MaxHeight="180"
                                             Text="{Binding Mensagem, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="MensagemTextBox_TextChanged"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             AcceptsReturn="True">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMessageEmpty}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBorder}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsMessageTooLong}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Warning}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <Grid Grid.Row="2" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MessageQualityTextStyle}"
                                                       Text="{Binding MessageQualityHint}" />
                                            <TextBlock Style="{StaticResource CopyFeedbackTextStyle}"
                                                       Text="{Binding CopyFeedback}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    MinWidth="100"
                                                    Height="34"
                                                    Margin="0,0,8,0"
                                                    IsEnabled="{Binding CanCopyAction}"
                                                    Click="Copy_Click">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCopyGeometry}" />
                                                    <TextBlock Text="Copiar" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource SecondaryButton}"
                                                    MinWidth="136"
                                                    Height="34"
                                                    Click="ApplyTemplate_Click">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconSparkleGeometry}" />
                                                    <TextBlock Text="Sugerir texto" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>

                        <Border Grid.Row="2"
                                Padding="14,10"
                                CornerRadius="0,0,14,14"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="0,1,0,0"
                                Background="{DynamicResource SurfaceMuted}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0"
                                           HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryButton}"
                                            MinWidth="140"
                                            Margin="0,0,8,8"
                                            IsEnabled="{Binding CanRegisterAction}"
                                            Click="Register_Click">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconPhoneGeometry}" />
                                            <TextBlock Text="Registrar contato" />
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource AccentButton}"
                                            MinWidth="104"
                                            Margin="0,0,8,8"
                                            Click="Email_Click"
                                            IsEnabled="{Binding CanEmailAction}">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconMailGeometry}" />
                                            <TextBlock Text="E-mail" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource SuccessButton}"
                                            MinWidth="116"
                                            Margin="0,0,8,8"
                                            Click="WhatsApp_Click"
                                            IsEnabled="{Binding CanWhatsAppAction}">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconPhoneGeometry}" />
                                            <TextBlock Text="WhatsApp" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{StaticResource SecondaryButton}"
                                            MinWidth="90"
                                            Margin="0,0,0,8"
                                            Click="Cancel_Click">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCloseGeometry}" />
                                            <TextBlock Text="Fechar" />
                                        </StackPanel>
                                    </Button>
                                </WrapPanel>

                                <StackPanel Grid.Row="1"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right">
                                    <Button Style="{StaticResource SecondaryButton}"
                                            MinWidth="260"
                                            Click="WhatsAppAutoPreview_Click">
                                        <Button.ToolTip>
                                            <ToolTip Content="Feature em desenvolvimento. Em breve para lançamento." />
                                        </Button.ToolTip>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Path Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconRebuildGeometry}" />
                                            <TextBlock Text="Cobran&#xE7;a WhatsApp autom&#xE1;tica"
                                                       Margin="6,0,0,0" />
                                            <Border Style="{StaticResource FeaturePreviewBadgeStyle}">
                                                <TextBlock Text="Beta / Em valida&#xE7;&#xE3;o"
                                                           Style="{StaticResource FeaturePreviewBadgeTextStyle}" />
                                            </Border>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <TextBlock Foreground="{DynamicResource TextMuted}"
                           FontSize="11.5"
                           Text="Visual inspirado em mensageria para acelerar revis&#xE3;o e envio." />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
