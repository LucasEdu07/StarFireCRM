                                  CanUserSortColumns="True"
                                  IsReadOnly="True"
                                  RowHeight="36"
                                  ColumnHeaderHeight="38"
                                  FontSize="12.8"
                                  RowStyle="{StaticResource PagamentoRowStyle}"
                                  ColumnHeaderStyle="{StaticResource UnifiedGridHeaderStyle}"
                                  Language="pt-BR"
                                  ItemsSource="{Binding Pagamentos}"
                                  SelectedItem="{Binding SelectedPagamento, Mode=TwoWay}">
