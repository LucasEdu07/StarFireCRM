                                                        <TextBlock Text="Canal oficial de atendimento"
                                                                   FontSize="10.8"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                   Opacity="0.92" />
                                                    </StackPanel>
                                                </Grid>
                                            </Button>

                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Height="38"
                                                    MinWidth="190"
                                                    Command="{Binding ContactSupportEmailCommand}"
                                                    ToolTip="Abrir e-mail com mensagem pronta">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                                               Text="&#xE715;"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    <TextBlock Text="Acionar via E-mail" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ConfigSectionCardStyle}" Margin="0,0,0,4"
                                    Visibility="{Binding IsConfigAvancadoSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid>
                                    <Grid x:Name="AdvancedConfigContentHost"
                                          IsHitTestVisible="{Binding IsAdvancedConfigUnlocked}">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Effect" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdvancedConfigUnlocked}" Value="False">
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <BlurEffect Radius="8" RenderingBias="Performance" />
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>

                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Configurações avançadas"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}" />

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource SecondaryButton}"
                                                        Height="32"
                                                        MinWidth="138"
                                                        Padding="12,0"
                                                        Visibility="{Binding IsAdvancedConfigUnlocked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Click="AdvancedRelockButton_Click">
                                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE72E;" />
                                                        <TextBlock Text="Bloquear" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>

                                            <TextBlock Text="Ações administrativas de manutenção do sistema."
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,0,0,12" />

                                            <WrapPanel>
                                                <Button Style="{StaticResource AdvancedActionButtonStyle}"
                                                        Command="{Binding RecreateClientesCommand}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Style="{StaticResource ToolbarIconStyle}"
                                                                   Text="&#xE74D;"
                                                                   VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="2"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="Recriar base de clientes"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                            <TextBlock Text="Apaga clientes e pagamentos vinculados"
                                                                       FontSize="10.8"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Opacity="0.86" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>

                                                <Button Style="{StaticResource AdvancedActionButtonStyle}"
                                                        Command="{Binding RecreatePagamentosCommand}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="10" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Style="{StaticResource ToolbarIconStyle}"
                                                                   Text="&#xE74D;"
                                                                   VerticalAlignment="Center" />
                                                        <StackPanel Grid.Column="2"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="Recriar base de pagamentos"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                            <TextBlock Text="Mantém clientes e limpa apenas pagamentos"
                                                                       FontSize="10.8"
                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                       Opacity="0.86" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>

                                    <Border Panel.ZIndex="5"
                                            Background="#8C0B1220">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAdvancedConfigUnlocked}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Border MaxWidth="450"
                                                    Padding="18"
                                                    Background="{DynamicResource CardBackground}"
                                                    BorderBrush="{DynamicResource BorderStrong}"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Effect="{StaticResource SoftShadow}">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                        <TextBlock Text="&#xE72E;"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="18"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   Margin="0,0,8,0"
                                                                   VerticalAlignment="Center" />
                                                        <TextBlock Text="Área protegida"
                                                                   FontSize="15"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>

                                                    <TextBlock Text="Digite a senha administrativa para habilitar os comandos avançados."
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,0,10" />

                                                    <PasswordBox x:Name="AdvancedUnlockPasswordBox"
                                                                 Style="{StaticResource AdvancedUnlockPasswordBoxStyle}"
                                                                 Margin="0,0,0,8"
                                                                 KeyDown="AdvancedUnlockPasswordBox_KeyDown"
                                                                 ToolTip="Informe a senha para liberar esta seção" />

                                                    <TextBlock Text="{Binding AdvancedUnlockStatusMessage}"
                                                               Margin="0,0,0,12">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource CaptionText}">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsAdvancedUnlockError}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource DangerFg}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <Button Style="{StaticResource PrimaryButton}"
                                                            Height="38"
                                                            MinWidth="164"
                                                            HorizontalAlignment="Right"
                                                            Click="AdvancedUnlockButton_Click">
                                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                                            <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE73E;" />
                                                            <TextBlock Text="Liberar acesso" />
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.RowSpan="3"
                Style="{StaticResource CardStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,84"
                Padding="12,10"
                Visibility="{Binding IsOperationInProgress, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="&#xE895;"
                           FontFamily="Segoe MDL2 Assets"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondary}" />
                <TextBlock Text="{Binding OperationStatusMessage}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" />
                <ProgressBar Margin="12,0,0,0"
                             Width="120"
                             Height="6"
                             IsIndeterminate="True"
                             VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.RowSpan="3"
                Style="{StaticResource ToastContainerStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,12"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.RenderTransform>
                <TranslateTransform Y="10" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.2" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Style="{StaticResource ToastIconStyle}" Margin="0,0,8,0" />
                <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource ButtonPrimaryFg}" FontWeight="SemiBold" />
                <Button Style="{StaticResource ToastInlineActionButtonStyle}"
                        Visibility="{Binding HasToastAction, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding ToastActionCommand}">
                    <TextBlock Text="{Binding ToastActionLabel}" />
                </Button>
            </StackPanel>
        </Border>

        <Grid x:Name="TourOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Background="#8C0B1220"
              Panel.ZIndex="999">
            <Canvas x:Name="TourCanvas">
                <Border x:Name="TourTargetHighlight"
                        Width="10"
                        Height="10"
                        CornerRadius="10"
                        BorderThickness="2"
                        BorderBrush="{DynamicResource PrimaryRed}"
                        Background="#22B91C1C"
                        IsHitTestVisible="False" />

                <Border x:Name="TourCallout"
                        Width="360"
                        MinHeight="180"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TourTitleText"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <Border Grid.Row="1"
                                Margin="0,8,0,10"
                                Padding="8,3"
                                CornerRadius="999"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                Background="{DynamicResource SurfaceMuted}"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="TourStepCounterText"
                                       Style="{StaticResource CaptionText}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" />
                        </Border>

                        <TextBlock x:Name="TourDescriptionText"
                                   Grid.Row="2"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="TourPrevButton"
                                    Grid.Column="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="34"
                                    MinWidth="96"
                                    Margin="0,0,8,0"
                                    Click="TourPrevButton_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76B;" />
                                    <TextBlock Text="Anterior" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="TourNextButton"
                                    Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="34"
                                    MinWidth="96"
                                    Click="TourNextButton_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Text="Próximo" />
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="34"
                                    MinWidth="96"
                                    Click="TourCloseButton_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Text="Encerrar" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock x:Name="TourArrowText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryRed}"
                           Text="?"
                           IsHitTestVisible="False" />
            </Canvas>
        </Grid>

        <Border x:Name="StartupTransitionOverlay"
                Grid.RowSpan="3"
                Panel.ZIndex="2000"
                Opacity="1"
                Visibility="Visible">
            <Border.Background>
                <DynamicResource ResourceKey="SplashShellBackground" />
            </Border.Background>
            <Grid>
                <Ellipse Width="460"
                         Height="460"
                         Fill="{DynamicResource SplashOrbPrimary}"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,-260,-260,0"
                         IsHitTestVisible="False" />

                <Ellipse Width="360"
                         Height="360"
                         Fill="{DynamicResource SplashOrbSecondary}"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Bottom"
                         Margin="-190,0,0,-190"
                         IsHitTestVisible="False" />

                <Border Margin="0"
                        Background="{DynamicResource SplashSheenOverlay}"
                        Opacity="0.65"
                        IsHitTestVisible="False" />

                <Border x:Name="StartupTransitionCard"
                        Width="320"
                        Height="172"
                        CornerRadius="18"
                        Padding="20"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource SplashLogoCardBorder}"
                        Background="{DynamicResource SplashLogoCardBackground}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Opacity="1"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="StartupCardScaleTransform" ScaleX="1" ScaleY="1" />
                            <TranslateTransform x:Name="StartupCardTranslateTransform" Y="0" />
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect Color="#B0000000"
                                          BlurRadius="22"
                                          ShadowDepth="0"
                                          Opacity="0.55" />
                    </Border.Effect>
                    <StackPanel>
                        <Image Width="178"
                               Height="72"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               Source="/ExtintorCrm.App;component/Assets/Images/startfire.png" />
                        <ProgressBar IsIndeterminate="True"
                                     Height="5"
                                     Margin="0,14,0,0"
                                     Foreground="{DynamicResource SplashProgressForeground}"
                                     Background="{DynamicResource SplashProgressTrack}"
                                     BorderThickness="0" />
                        <TextBlock Text="Inicializando ambiente..."
                                   Margin="0,11,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SplashTitleForeground}"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>






















