<Window x:Class="ExtintorCrm.App.Presentation.ClienteFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Novo Cliente"
        Height="700"
        Width="920"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.24"
                                     EasingFunction="{StaticResource DialogEaseOut}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Window.Resources>
        <Style x:Key="InputStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Height" Value="40" />
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Novo Cliente"
                           Style="{StaticResource DialogTitleTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Novo Cliente" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                <TextBlock Text="Preencha os dados principais para cadastrar um novo cliente." Foreground="{DynamicResource TextSecondary}" Margin="0,4,0,0" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource DialogSurfaceCardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Dados" FontSize="16" FontWeight="SemiBold" Grid.ColumnSpan="3" Margin="0,0,0,12" />

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="Nome *" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox x:Name="NomeTextBox"
                                         Style="{StaticResource InputStyle}"
                                         Text="{Binding NomeFantasia, UpdateSourceTrigger=PropertyChanged}"
                                         TextChanged="NomeTextBox_TextChanged" />
                                <TextBlock x:Name="NomeValidationText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource DangerFg}"
                                           Visibility="Collapsed" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="CPF/CNPJ *" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox x:Name="CpfTextBox"
                                         Style="{StaticResource InputStyle}"
                                         Text="{Binding CpfCnpj}"
                                         TextChanged="CpfTextBox_TextChanged"
                                         LostFocus="CpfTextBox_LostFocus" />
                                <TextBlock x:Name="CpfValidationText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource DangerFg}"
                                           Visibility="Collapsed" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Text="Contato" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Contato}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DialogSurfaceCardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Contato" FontSize="16" FontWeight="SemiBold" Grid.ColumnSpan="3" Margin="0,0,0,12" />

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="Telefone" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox x:Name="TelefoneTextBox" Style="{StaticResource InputStyle}" Text="{Binding Telefone1}" LostFocus="TelefoneTextBox_LostFocus" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="E-mail" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Email}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Text="Razão social" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding RazaoSocial}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                                <TextBlock Text="Endereço" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Endereco}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DialogSurfaceCardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="Endereço e Vencimentos" FontSize="16" FontWeight="SemiBold" Grid.ColumnSpan="3" Margin="0,0,0,12" />

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="Cidade" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Cidade}" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="2">
                                <TextBlock Text="UF" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding UF}" MaxLength="2" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,12,0,0">
                                <TextBlock Text="Vencimento dos extintores" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                            SelectedDate="{Binding VencimentoExtintores}" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,12,0,0">
                                <TextBlock Text="Vencimento do alvará" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                            SelectedDate="{Binding VencimentoAlvara}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,12,0,0">
                                <TextBlock Text="Tipo" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding Tipo}" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,12,0,0">
                                <TextBlock Text="Nº Alvará" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <TextBox Style="{StaticResource InputStyle}" Text="{Binding NumeroAlvara}" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DialogSurfaceCardStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Status da recarga" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Height="40"
                                          SelectedValuePath="Content"
                                          SelectedValue="{Binding StatusRecarga, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Não informado" />
                                    <ComboBoxItem Content="Em dia" />
                                    <ComboBoxItem Content="Pendente" />
                                    <ComboBoxItem Content="Vencido" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Status do alvará" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6" />
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Height="40"
                                          SelectedValuePath="Content"
                                          SelectedValue="{Binding StatusAlvara, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBoxItem Content="Não informado" />
                                    <ComboBoxItem Content="Em dia" />
                                    <ComboBoxItem Content="Pendente" />
                                    <ComboBoxItem Content="Vencido" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource DialogSurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Observações" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBox Height="100"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"
                                     Text="{Binding Observacoes}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource PrimaryButton}" Width="132" Margin="0,0,8,0" Click="Salvar_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Style="{StaticResource ToolbarVectorIconPrimaryStyle}" Data="{StaticResource IconSaveGeometry}" />
                        <TextBlock Text="Salvar" Foreground="{DynamicResource ButtonPrimaryFg}" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Width="132" IsCancel="True">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCloseGeometry}" />
                        <TextBlock Text="Cancelar" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>



