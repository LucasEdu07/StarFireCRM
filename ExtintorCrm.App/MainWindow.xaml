<Window x:Class="ExtintorCrm.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:ExtintorCrm.App.Presentation.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:ExtintorCrm.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Star Fire CRM - Gestão de Clientes"
        Height="{Binding MainWindowHeight, Mode=OneWay}"
        Width="{Binding MainWindowWidth, Mode=OneWay}"
        Left="{Binding MainWindowLeft, Mode=OneWay}"
        Top="{Binding MainWindowTop, Mode=OneWay}"
        ResizeMode="CanMinimize"
        WindowState="{Binding MainWindowState, Mode=OneWay}"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="{Binding MainTopmost, Mode=OneWay}"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontFamily="Segoe UI Variable"
        FontSize="14">
    <Window.Resources>
        <ResourceDictionary>
            <local:DashboardKpiItemWidthConverter x:Key="DashboardKpiItemWidthConverter" />
            <local:DoubleLessThanConverter x:Key="DoubleLessThanConverter" />
            <local:ValuesEqualMultiConverter x:Key="ValuesEqualMultiConverter" />
            <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,3" />
                <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencendo">
                        <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsAtivo}" Value="False">
                        <Setter Property="Background" Value="{DynamicResource ClienteInactiveBadgeBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ClienteInactiveBadgeBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="StatusBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencendo">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsAtivo}" Value="False">
                        <Setter Property="Foreground" Value="{DynamicResource ClienteInactiveBadgeFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="MetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Padding" Value="18" />
                <Setter Property="Margin" Value="0,0,16,16" />
            </Style>

            <CollectionViewSource x:Key="GroupedCriticalAlertsTop" Source="{Binding CriticalAlertsTop}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Tipo" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <CollectionViewSource x:Key="GroupedCriticalAlertsAll" Source="{Binding CriticalAlertsAll}">
                <CollectionViewSource.GroupDescriptions>
                    <PropertyGroupDescription PropertyName="Tipo" />
                </CollectionViewSource.GroupDescriptions>
            </CollectionViewSource>

            <Style x:Key="DashboardAnimatedCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Opacity" Value="0" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <ScaleTransform ScaleX="0.992" ScaleY="0.992" />
                            <TranslateTransform Y="12" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryRedHover}" />
                        <Setter Property="Effect" Value="{StaticResource SoftShadowHover}" />
                    </Trigger>
                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                 From="0"
                                                 To="1"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 From="12"
                                                 To="0"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 From="0.992"
                                                 To="1"
                                                 Duration="0:0:0.24" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 From="0.992"
                                                 To="1"
                                                 Duration="0:0:0.24" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 To="-4"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1.01"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1.01"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                 To="0"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                 To="1"
                                                 Duration="0:0:0.16" />
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DashboardKpiCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
                <Setter Property="Height" Value="174" />
                <Setter Property="MinHeight" Value="174" />
                <Setter Property="Padding" Value="14,13" />
                <Setter Property="Margin" Value="0,0,10,10" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="UseLayoutRounding" Value="True" />
                <Setter Property="Effect" Value="{StaticResource SoftShadow}" />
                <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <ScaleTransform ScaleX="1" ScaleY="1" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Severity}" Value="Danger">
                        <Setter Property="BorderBrush" Value="{DynamicResource DangerBorder}" />
                        <Setter Property="Background" Value="{DynamicResource KpiDangerCardBackground}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Severity}" Value="Warning">
                        <Setter Property="BorderBrush" Value="{DynamicResource Warning}" />
                        <Setter Property="Background" Value="{DynamicResource KpiWarningCardBackground}" />
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Opacity" Value="0.98" />
                        <Setter Property="Effect" Value="{StaticResource SoftShadowHover}" />
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.008" ScaleY="1.008" />
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="DashboardKpiIconWrapStyle" TargetType="Border">
                <Setter Property="Width" Value="38" />
                <Setter Property="Height" Value="38" />
                <Setter Property="CornerRadius" Value="11" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <Style x:Key="DashboardKpiValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="29" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                <Setter Property="Margin" Value="0,9,0,2" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="MinHeight" Value="32" />
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="LineHeight" Value="32" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="DashboardKpiTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12.2" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="LineHeight" Value="15.5" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
                <Setter Property="MaxHeight" Value="31" />
            </Style>

            <Style x:Key="DashboardKpiBadgeStyle" TargetType="Border" BasedOn="{StaticResource BadgePill}">
                <Setter Property="MinWidth" Value="74" />
                <Setter Property="Padding" Value="8,3" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="VerticalAlignment" Value="Top" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
            </Style>

            <Style x:Key="DashboardKpiBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10.8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            </Style>

            <Style x:Key="DashboardKpiMetaRowStyle" TargetType="DockPanel">
                <Setter Property="LastChildFill" Value="False" />
                <Setter Property="Margin" Value="0,11,0,0" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>

            <Style x:Key="DashboardKpiMetaTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="10.8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            </Style>

            <Style x:Key="DashboardKpiMetaGlyphStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            </Style>

            <Style x:Key="AlertStripStyle" TargetType="Border">
                <Setter Property="Width" Value="5" />
                <Setter Property="CornerRadius" Value="8,0,0,8" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Nivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Nivel}" Value="OK">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="AlertDayBadgeStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Nivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Nivel}" Value="OK">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="UnifiedGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                <Setter Property="Padding" Value="2" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowHoverBackground}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowSelectedBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource RowSelectedBorder}" />
                        <Setter Property="BorderThickness" Value="3,1,1,1" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style x:Key="ClienteRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource UnifiedGridRowStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsAtivo}" Value="False">
                        <Setter Property="Background" Value="{DynamicResource ClienteInactiveRowBackground}" />
                    </DataTrigger>
                    <MultiDataTrigger>
                        <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding IsAtivo}" Value="False" />
                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                        </MultiDataTrigger.Conditions>
                        <Setter Property="Background" Value="{DynamicResource ClienteInactiveRowHoverBackground}" />
                    </MultiDataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="UnifiedGridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                <Setter Property="Background" Value="{DynamicResource DataGridHeaderBackground}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                <Setter Property="Padding" Value="12,8" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
            </Style>

            <Style x:Key="PagamentoRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource UnifiedGridRowStyle}">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource RowSelectedBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource RowSelectedBorder}" />
                        <Setter Property="BorderThickness" Value="3,1,1,1" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="GridTextCellBaseStyle" TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            </Style>

            <Style x:Key="LeftCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextCellBaseStyle}">
                <Setter Property="TextAlignment" Value="Left" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="MoneyCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextCellBaseStyle}">
                <Setter Property="TextAlignment" Value="Right" />
                <Setter Property="HorizontalAlignment" Value="Right" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,8,0" />
            </Style>

            <Style x:Key="CenterCellStyle" TargetType="TextBlock" BasedOn="{StaticResource GridTextCellBaseStyle}">
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style x:Key="ToolbarIconStyle" TargetType="TextBlock" BasedOn="{StaticResource ButtonGlyphIconStyle}">
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Style>

            <Style x:Key="PagoBadgeStyle" TargetType="Border">
                <Setter Property="MinWidth" Value="94" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource SurfaceBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Pago}" Value="True">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="PagoBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Text" Value="Aberto" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Pago}" Value="True">
                        <Setter Property="Text" Value="Pago" />
                        <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CriticalGridRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource UnifiedGridRowStyle}">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="ToolTip" Value="Abrir perfil do cliente" />
                <Setter Property="MinHeight" Value="44" />
            </Style>

            <Style x:Key="CriticalClienteTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13.5" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                <Setter Property="Margin" Value="6,0,8,0" />
            </Style>

            <Style x:Key="CriticalTypeBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                <Setter Property="MinWidth" Value="94" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tipo}" Value="Pagamento">
                        <Setter Property="Background" Value="{DynamicResource AccentBlueBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tipo}" Value="Extintor">
                        <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tipo}" Value="Alvará">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CriticalDaysBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,5" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BadgeSuccessBg}" />
                <Setter Property="MinWidth" Value="62" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencendo">
                        <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeWarningBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="CriticalDaysBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource BadgeSuccessFg}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="12.5" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencendo">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SettingsToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource ModernLightSwitch3D}" />

            <Style x:Key="VanillaIntensitySliderStyle" TargetType="Slider">
                <Setter Property="Height" Value="22" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center">
                                <Border Height="6"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        Background="{DynamicResource SurfaceMuted}"
                                        BorderBrush="{DynamicResource ControlBorder}"
                                        BorderThickness="1" />
                                <Track x:Name="PART_Track"
                                       VerticalAlignment="Center">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                      Background="{DynamicResource ActionAccentBg}"
                                                      BorderThickness="0" />
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="14"
                                               Height="14"
                                               BorderThickness="1"
                                               Background="{DynamicResource PrimaryRed}"
                                               BorderBrush="{DynamicResource PrimaryRedHover}" />
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                      Background="Transparent"
                                                      BorderThickness="0" />
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ToastContainerStyle" TargetType="Border">
                <Setter Property="Padding" Value="{StaticResource Design.Space.ToastPadding}" />
                <Setter Property="CornerRadius" Value="{StaticResource Design.Corner.Md}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource ToastSuccessBg}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ToastSuccessBorder}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ToastKind}" Value="Error">
                        <Setter Property="Background" Value="{DynamicResource ToastErrorBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ToastErrorBorder}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ToastKind}" Value="Info">
                        <Setter Property="Background" Value="{DynamicResource ToastInfoBg}" />
                        <Setter Property="BorderBrush" Value="{DynamicResource ToastInfoBorder}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ToastIconStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                <Setter Property="Text" Value="&#xE73E;" />
                <Setter Property="Foreground" Value="{DynamicResource ToastSuccessFg}" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding ToastKind}" Value="Error">
                        <Setter Property="Text" Value="&#xEA39;" />
                        <Setter Property="Foreground" Value="{DynamicResource ToastErrorFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding ToastKind}" Value="Info">
