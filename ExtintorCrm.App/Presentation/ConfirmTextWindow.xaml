<Window x:Class="ExtintorCrm.App.Presentation.ConfirmTextWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação"
        Width="520"
        Height="280"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding DialogTitle}" Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="18"
                Padding="16"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" />

                <TextBlock Grid.Row="1"
                           Margin="0,12,0,0"
                           Text="{Binding Instruction}"
                           Foreground="{DynamicResource TextSecondary}" />

                <TextBox x:Name="ValueTextBox"
                         Grid.Row="2"
                         Margin="0,8,0,0"
                         Height="40"
                         Style="{StaticResource ModernTextBox}" />

                <TextBlock Grid.Row="3"
                           Margin="0,10,0,0"
                           Text="{Binding ErrorMessage}"
                           Foreground="{DynamicResource DangerFg}" />

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,14,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            Width="116"
                            Height="38"
                            Margin="0,0,8,0"
                            Click="Cancel_Click">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                            <TextBlock Text="Cancelar" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource DangerButton}"
                            Width="140"
                            Height="38"
                            Click="Confirm_Click">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE73E;" />
                            <TextBlock Text="Confirmar ação" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>

