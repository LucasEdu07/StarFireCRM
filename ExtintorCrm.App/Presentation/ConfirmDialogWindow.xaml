<Window x:Class="ExtintorCrm.App.Presentation.ConfirmDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmação"
        Width="460"
        MinHeight="220"
        MaxHeight="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.18" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Titulo}"
                           Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Border Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="{Binding Titulo}" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />

                    <TextBlock Grid.Row="1"
                               Margin="0,12,0,0"
                               MaxWidth="380"
                               Text="{Binding Mensagem}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}" />

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Width="126" IsCancel="True" Margin="0,0,10,0">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                                <TextBlock Text="Cancelar" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource PrimaryButton}" Width="126" IsDefault="True" Click="Confirmar_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE73E;" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                <TextBlock Text="Confirmar" Foreground="{DynamicResource ButtonPrimaryFg}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

