<Window x:Class="ExtintorCrm.App.Presentation.CobrancaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cobrança Inteligente"
        Width="980"
        Height="650"
        MinWidth="920"
        MinHeight="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.18" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource SurfaceBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Cobrança Inteligente"
                           Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="Cancel_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding ClienteNome}" FontSize="20" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding ContatoInfo}"
                                       Margin="0,6,0,0"
                                       Foreground="{DynamicResource TextSecondary}" />
                        </StackPanel>

                        <Border Grid.Row="1"
                                Margin="0,12,0,12"
                                Padding="10,8"
                                CornerRadius="10"
                                Background="{DynamicResource SurfaceMuted}"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1">
                            <TextBlock Text="Revise a mensagem e escolha o canal. A interação será registrada no histórico da cobrança."
                                       Foreground="{DynamicResource TextSecondary}" />
                        </Border>

                        <TextBox Grid.Row="2"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding Mensagem, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="MensagemTextBox_TextChanged"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 AcceptsReturn="True"
                                 MinHeight="300" />
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Resumo da cobrança"
                                           FontSize="15.5"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />
                                <TextBlock Text="Valor" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding ValorResumo}" Margin="0,2,0,8" />
                                <TextBlock Text="Vencimento" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding VencimentoResumo}" Margin="0,2,0,8" />
                                <TextBlock Text="Prazo" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding PrazoResumo}" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Estratégia"
                                           FontSize="15.5"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />

                                <TextBlock Text="Etapa da régua" Style="{StaticResource SectionLabel}" />
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Height="38"
                                          Margin="0,2,0,10"
                                          ItemsSource="{Binding EtapaOptions}"
                                          SelectedItem="{Binding EtapaSelecionada}" />

                                <TextBlock Text="Tom da mensagem" Style="{StaticResource SectionLabel}" />
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Height="38"
                                          Margin="0,2,0,12"
                                          ItemsSource="{Binding TomOptions}"
                                          SelectedItem="{Binding TomSelecionado}" />

                                <Button Style="{StaticResource SecondaryButton}"
                                        MinWidth="148"
                                        Height="34"
                                        HorizontalAlignment="Left"
                                        Click="ApplyTemplate_Click">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE70F;" />
                                        <TextBlock Text="Aplicar sugestão" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCard}" MinHeight="260">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Histórico recente"
                                           FontSize="15.5"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,10" />

                                <Grid Grid.Row="1">
                                    <ListBox ItemsSource="{Binding HistoricoItens}"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="False">
                                        <ListBox.Style>
                                            <Style TargetType="ListBox">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasHistorico}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.Style>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Margin" Value="0,0,0,8" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="10,8"
                                                        CornerRadius="8"
                                                        Background="{DynamicResource SurfaceMuted}"
                                                        BorderBrush="{DynamicResource ControlBorder}"
                                                        BorderThickness="1">
                                                    <TextBlock Text="{Binding}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="12.4" />
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <TextBlock Text="Nenhuma interação registrada ainda."
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasHistorico}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,14,0,0">
                <Button Style="{StaticResource SecondaryButton}"
                        MinWidth="156"
                        Margin="0,0,8,0"
                        Click="Register_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8D4;" />
                        <TextBlock Text="Registrar contato" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryButton}"
                        MinWidth="106"
                        Margin="0,0,8,0"
                        Click="Copy_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8C8;" />
                        <TextBlock Text="Copiar" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource AccentButton}"
                        MinWidth="110"
                        Margin="0,0,8,0"
                        Click="Email_Click"
                        IsEnabled="{Binding CanSendEmail}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                   Text="&#xE715;"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                        <TextBlock Text="E-mail" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource PrimaryButton}"
                        MinWidth="122"
                        Margin="0,0,8,0"
                        Click="WhatsApp_Click"
                        IsEnabled="{Binding CanSendWhatsApp}">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                   Text="&#xE8BD;"
                                   Foreground="{DynamicResource ButtonPrimaryFg}" />
                        <TextBlock Text="WhatsApp" Foreground="{DynamicResource ButtonPrimaryFg}" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource SecondaryButton}"
                        MinWidth="96"
                        Click="Cancel_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE711;" />
                        <TextBlock Text="Fechar" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
