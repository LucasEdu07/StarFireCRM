<Window x:Class="ExtintorCrm.App.Presentation.DashboardAlertsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Conferência de Avisos"
        Width="980"
        Height="640"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.24"
                                     EasingFunction="{StaticResource DialogEaseOut}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Window.Resources>
        <Style x:Key="AlertsLeftCellStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="AlertsCenterCellStyle" TargetType="TextBlock" BasedOn="{StaticResource AlertsLeftCellStyle}">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="WindowTitleText" Style="{StaticResource DialogTitleTextStyle}" Text="Conferência de Avisos" />
                <Button Grid.Column="1"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,16,20,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource DialogAnimatedCardStyle}" Padding="14" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />
                    <TextBlock x:Name="SubtitleText"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondary}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource DialogAnimatedCardStyle}" Padding="10">
                <DataGrid x:Name="AlertsGrid"
                          Style="{StaticResource CleanDataGrid}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          RowHeight="44"
                          ColumnHeaderHeight="40"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          MouseDoubleClick="AlertsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNome}" Width="2.2*" ElementStyle="{StaticResource AlertsLeftCellStyle}" />
                        <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="130" ElementStyle="{StaticResource AlertsLeftCellStyle}" />
                        <DataGridTextColumn Header="Vencimento" Binding="{Binding DataVencimentoTexto}" Width="130" ElementStyle="{StaticResource AlertsCenterCellStyle}" />
                        <DataGridTextColumn Header="Dias" Binding="{Binding DiasTexto}" Width="90" ElementStyle="{StaticResource AlertsCenterCellStyle}" />
                        <DataGridTextColumn Header="Situação" Binding="{Binding SituacaoTexto}" Width="130" ElementStyle="{StaticResource AlertsCenterCellStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,20,20">
            <Button Style="{StaticResource SecondaryButton}" Width="128" Margin="0,0,8,0" Click="CloseButton_Click">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCloseGeometry}" />
                    <TextBlock Text="Fechar" />
                </StackPanel>
            </Button>
            <Button Style="{StaticResource PrimaryButton}" Width="152" Click="OpenProfileButton_Click">
                <StackPanel Style="{StaticResource IconButtonContent}">
                    <Path Style="{StaticResource ToolbarVectorIconPrimaryStyle}" Data="{StaticResource IconUserGeometry}" />
                    <TextBlock Text="Abrir Perfil" Foreground="{DynamicResource ButtonPrimaryFg}" />
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>



