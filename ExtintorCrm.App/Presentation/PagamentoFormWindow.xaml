<Window x:Class="ExtintorCrm.App.Presentation.PagamentoFormWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pagamento"
        Height="780"
        MinHeight="720"
        Width="1120"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.24"
                                     EasingFunction="{StaticResource DialogEaseOut}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="SectionCard" TargetType="Border" BasedOn="{StaticResource DialogSurfaceCardStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="14" />
        </Style>

        <Style x:Key="StatusChip" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Background" Value="{DynamicResource BadgeMutedBg}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="StatusChipText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource BadgeMutedFg}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="InnerTabControlStyle" TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource SurfaceBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6,4">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                            <ContentPresenter Grid.Row="1"
                                              Margin="0,10,0,0"
                                              x:Name="PART_SelectedContentHost"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InnerTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Margin="0,0,8,0"
                                CornerRadius="8"
                                BorderThickness="0,0,0,2"
                                BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource ControlBackgroundHover}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder"
                                        Property="Background"
                                        Value="{DynamicResource CardBackground}" />
                                <Setter TargetName="TabBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource PrimaryRed}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource SurfaceBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding WindowTitle}" Style="{StaticResource DialogTitleTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="22" Background="{DynamicResource SurfaceBackground}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionCard}" Margin="0,0,0,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding WindowTitle}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />
                        <TextBlock Text="{Binding WindowSubtitle}"
                                   Margin="0,4,0,0"
                                   Foreground="{DynamicResource TextSecondary}" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="Cliente:" Style="{StaticResource SectionLabel}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding ClienteNomeSelecionado}" Margin="0,0,16,0" />
                            <TextBlock Text="Vencimento:" Style="{StaticResource SectionLabel}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding DataVencimento, StringFormat=dd/MM/yyyy}" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource StatusChip}" VerticalAlignment="Top">
                        <TextBlock Text="{Binding StatusFinanceiro}" Style="{StaticResource StatusChipText}" />
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="7*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="Dados da cobrança"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,12"
                                       Foreground="{DynamicResource TextPrimary}" />

                            <StackPanel Visibility="{Binding IsClienteSelectable, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,12">
                                <TextBlock Text="Cliente *" Style="{StaticResource SectionLabel}" />
                                <ComboBox x:Name="ClienteComboBox"
                                          Style="{StaticResource ModernComboBox}"
                                          Height="40"
                                          MaxDropDownHeight="280"
                                          IsTextSearchEnabled="True"
                                          ScrollViewer.CanContentScroll="True"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                                          ItemsSource="{Binding Clientes}"
                                          SelectedValuePath="Id"
                                          DisplayMemberPath="Nome"
                                          SelectionChanged="ClienteComboBox_SelectionChanged"
                                          SelectedValue="{Binding ClienteId}" />
                                <TextBlock x:Name="ClienteValidationText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource DangerFg}"
                                           Visibility="Collapsed" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsClienteReadOnly, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,12">
                                <TextBlock Text="Cliente" Style="{StaticResource SectionLabel}" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Height="40"
                                         IsReadOnly="True"
                                         Text="{Binding ClienteNomeSelecionado, Mode=OneWay}" />
                                <TextBlock Text="CPF/CNPJ" Style="{StaticResource SectionLabel}" Margin="0,10,0,6" />
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Height="40"
                                         IsReadOnly="True"
                                         Text="{Binding CpfCnpjClienteSelecionado, Mode=OneWay}" />
                            </StackPanel>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Tipo" Style="{StaticResource SectionLabel}" />
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              Height="40"
                                              ItemsSource="{Binding TipoOptions}"
                                              SelectedItem="{Binding Tipo}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Status" Style="{StaticResource SectionLabel}" />
                                    <ComboBox Style="{StaticResource ModernComboBox}"
                                              Height="40"
                                              ItemsSource="{Binding StatusOptions}"
                                              SelectedItem="{Binding StatusFinanceiro}" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Categoria" Style="{StaticResource SectionLabel}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Height="40"
                                             Text="{Binding Categoria}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Subcategoria" Style="{StaticResource SectionLabel}" />
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Height="40"
                                             Text="{Binding Subcategoria}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Descrição" Style="{StaticResource SectionLabel}" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Height="40"
                                     Margin="0,0,0,12"
                                     Text="{Binding Descricao}" />

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Valor *" Style="{StaticResource SectionLabel}" />
                                    <TextBox x:Name="ValorTextBox"
                                             Style="{StaticResource ModernTextBox}"
                                             Height="40"
                                             GotFocus="ValorTextBox_GotFocus"
                                             PreviewTextInput="ValorTextBox_PreviewTextInput"
                                             TextChanged="ValorTextBox_TextChanged"
                                             LostFocus="ValorTextBox_LostFocus"
                                             DataObject.Pasting="ValorTextBox_Pasting" />
                                    <TextBlock x:Name="ValorValidationText"
                                               Margin="2,6,0,0"
                                               Foreground="{DynamicResource DangerFg}"
                                               FontSize="12"
                                               Visibility="Collapsed"
                                               Text="Informe um valor válido maior que zero." />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Data de vencimento *" Style="{StaticResource SectionLabel}" />
                                    <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                                SelectedDate="{Binding DataVencimento}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Observações"
                                       Style="{StaticResource SectionLabel}"
                                       Margin="0,12,0,6" />
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     MinHeight="90"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding Observacoes}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource SectionCard}">
                        <TabControl Style="{StaticResource InnerTabControlStyle}"
                                    ItemContainerStyle="{StaticResource InnerTabItemStyle}">
                            <TabItem Header="Status">
                                <StackPanel>
                                    <TextBlock Text="Situação de pagamento"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,12"
                                               Foreground="{DynamicResource TextPrimary}" />

                                    <CheckBox Content="Pagamento já foi realizado"
                                              IsChecked="{Binding Pago}"
                                              Style="{StaticResource ModernCheckBox}"
                                              Margin="0,0,0,10" />

                                    <TextBlock Text="Data de pagamento" Style="{StaticResource SectionLabel}" />
                                    <DatePicker Style="{StaticResource ModernDatePickerStyle}"
                                                SelectedDate="{Binding DataPagamento}"
                                                 IsEnabled="{Binding Pago}" />
                                </StackPanel>
                            </TabItem>

                            <TabItem Header="Documentos">
                                <StackPanel>
                                    <Border Style="{StaticResource AttachmentSectionCardStyle}"
                                            Padding="10,9">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Documentos do pagamento"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}" />
                                                <TextBlock x:Name="PagamentoAnexosCountText"
                                                           Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           FontSize="12" />
                                            </Grid>

                                            <Grid Margin="0,10,0,0"
                                                  Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                                                    <Button x:Name="AnexarPagamentoButton"
                                                            Style="{StaticResource AccentButton}"
                                                            Height="34"
                                                            MinWidth="132"
                                                            Margin="0,0,10,0"
                                                            Click="AnexarPagamentoDocumento_Click">
                                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconAttachmentGeometry}" />
                                                            <TextBlock Text="Anexar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                        </StackPanel>
                                                    </Button>

                                                    <Button x:Name="AbrirPagamentoButton"
                                                            Style="{StaticResource SecondaryButton}"
                                                            Height="34"
                                                            MinWidth="122"
                                                            Margin="0,0,10,0"
                                                            Click="AbrirPagamentoDocumento_Click">
                                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                                            <Path  Style="{StaticResource ToolbarVectorIconDangerStyle}" Data="{StaticResource IconOpenExternalGeometry}" />
                                                            <TextBlock Text="Abrir" />
                                                        </StackPanel>
                                                    </Button>

                                                    <Button x:Name="ExcluirPagamentoButton"
                                                            Style="{StaticResource DangerButton}"
                                                            Height="34"
                                                            MinWidth="122"
                                                            Click="ExcluirPagamentoDocumento_Click">
                                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                                            <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconTrashGeometry}" />
                                                            <TextBlock Text="Excluir" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                        </StackPanel>
                                                    </Button>
                                                </WrapPanel>

                                                <DataGrid x:Name="PagamentoAnexosDataGrid"
                                                          Grid.Row="1"
                                                          Style="{StaticResource CleanDataGrid}"
                                                          AutoGenerateColumns="False"
                                                          IsReadOnly="True"
                                                          CanUserAddRows="False"
                                                          CanUserDeleteRows="False"
                                                          CanUserResizeRows="False"
                                                          SelectionMode="Single"
                                                          Height="300"
                                                          RowHeight="52"
                                                          ColumnHeaderHeight="40"
                                                          FontSize="12.4"
                                                          SelectionChanged="PagamentoAnexosDataGrid_SelectionChanged">
                                                    <DataGrid.Columns>
                                                        <DataGridTemplateColumn Header="Documento" Width="2.5*" CellTemplate="{StaticResource AttachmentExplorerFileTemplate}" />
                                                        <DataGridTextColumn Header="Tamanho" Binding="{Binding TamanhoTexto}" Width="110" />
                                                        <DataGridTextColumn Header="Incluído em" Binding="{Binding CriadoEmTexto}" Width="150" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                            </Grid>

                                            <TextBlock Text="Anexe documentos após salvar o pagamento."
                                                       Margin="0,10,0,0"
                                                       Foreground="{DynamicResource TextSecondary}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </Border>
                </Grid>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource SecondaryButton}"
                        Width="128"
                        Margin="0,0,8,0"
                        IsCancel="True">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCloseGeometry}" />
                        <TextBlock Text="Fechar" />
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource PrimaryButton}"
                        Width="174"
                        Click="Salvar_Click">
                    <StackPanel Style="{StaticResource IconButtonContent}">
                        <Path Style="{StaticResource ToolbarVectorIconPrimaryStyle}" Data="{StaticResource IconSaveGeometry}" />
                        <TextBlock Text="Salvar alterações"
                                   Foreground="{DynamicResource ButtonPrimaryFg}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>



