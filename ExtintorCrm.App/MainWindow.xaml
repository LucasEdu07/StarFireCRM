                                        <TextBlock Text="E-mail: lucas_souzasjc@hotmail.com"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   Margin="0,2,0,10" />

                                        <WrapPanel>
                                            <Button Style="{StaticResource AccentButton}"
                                                    Height="38"
                                                    MinWidth="210"
                                                    Margin="0,0,8,0"
                                                    Command="{Binding ContactSupportWhatsAppCommand}"
                                                    ToolTip="Abrir WhatsApp com mensagem pronta">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <Border Width="16" Height="16" CornerRadius="8" Background="#25D366">
                                                        <TextBlock Text="W"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   FontSize="9"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <TextBlock Text="Acionar via WhatsApp" />
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{StaticResource SecondaryButton}"
                                                    Height="38"
                                                    MinWidth="190"
                                                    Command="{Binding ContactSupportEmailCommand}"
                                                    ToolTip="Abrir e-mail com mensagem pronta">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                                               Text="&#xE715;"
                                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    <TextBlock Text="Acionar via E-mail" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                            </Border>

                            <Border Style="{StaticResource ConfigSectionCardStyle}" Margin="0,0,0,4"
                                    Visibility="{Binding IsConfigAvancadoSection, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="Configurações avançadas" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,6" />
                                        <TextBlock Text="Ações administrativas de manutenção do sistema." Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,12" />

                                        <WrapPanel>
                                            <Button Style="{StaticResource DangerButton}"
                                                    MinWidth="260"
                                                    Height="40"
                                                    Margin="0,0,10,0"
                                                    Command="{Binding RecreateClientesCommand}">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74D;" />
                                                    <TextBlock Text="Recriar base de clientes" />
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{StaticResource DangerButton}"
                                                    MinWidth="260"
                                                    Height="40"
                                                    Command="{Binding RecreatePagamentosCommand}">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE74D;" />
                                                    <TextBlock Text="Recriar base de pagamentos" />
                                                </StackPanel>
                                            </Button>
                                        </WrapPanel>
                                    </StackPanel>
                            </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.RowSpan="3"
                Style="{StaticResource ToastContainerStyle}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,12"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.RenderTransform>
                <TranslateTransform Y="10" />
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.2" />
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="10" To="0" Duration="0:0:0.2" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource ToastIconStyle}" Margin="0,0,8,0" />
                <TextBlock Text="{Binding ToastMessage}" Foreground="{DynamicResource ButtonPrimaryFg}" FontWeight="SemiBold" />
            </StackPanel>
        </Border>

        <Grid x:Name="TourOverlay"
              Grid.RowSpan="3"
              Visibility="Collapsed"
              Background="#8C0B1220"
              Panel.ZIndex="999">
            <Canvas x:Name="TourCanvas">
                <Border x:Name="TourTargetHighlight"
                        Width="10"
                        Height="10"
                        CornerRadius="10"
                        BorderThickness="2"
                        BorderBrush="{DynamicResource PrimaryRed}"
                        Background="#22B91C1C"
                        IsHitTestVisible="False" />

                <Border x:Name="TourCallout"
                        Width="360"
                        MinHeight="180"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14"
                        Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="TourTitleText"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <Border Grid.Row="1"
                                Margin="0,8,0,10"
                                Padding="8,3"
                                CornerRadius="999"
                                BorderBrush="{DynamicResource ControlBorder}"
                                BorderThickness="1"
                                Background="{DynamicResource SurfaceMuted}"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="TourStepCounterText"
                                       Style="{StaticResource CaptionText}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" />
                        </Border>

                        <TextBlock x:Name="TourDescriptionText"
                                   Grid.Row="2"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimary}" />

                        <Grid Grid.Row="3" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="TourPrevButton"
                                    Grid.Column="0"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="34"
                                    MinWidth="96"
                                    Margin="0,0,8,0"
                                    Click="TourPrevButton_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76B;" />
                                    <TextBlock Text="Anterior" />
                                </StackPanel>
                            </Button>

                            <Button x:Name="TourNextButton"
                                    Grid.Column="1"
                                    Style="{StaticResource SecondaryButton}"
                                    Height="34"
                                    MinWidth="96"
                                    Click="TourNextButton_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Text="Próximo" />
                                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE76C;" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3"
                                    Style="{StaticResource PrimaryButton}"
                                    Height="34"
                                    MinWidth="96"
                                    Click="TourCloseButton_Click">
                                <StackPanel Style="{StaticResource IconButtonContent}">
                                    <TextBlock Text="Encerrar" Foreground="{DynamicResource ButtonPrimaryFg}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock x:Name="TourArrowText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryRed}"
                           Text="?"
                           IsHitTestVisible="False" />
            </Canvas>
        </Grid>
    </Grid>
</Window>






















