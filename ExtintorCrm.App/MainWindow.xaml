                        <ControlTemplate TargetType="TabControl">
                            <Grid KeyboardNavigation.TabNavigation="Local">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource SurfaceMuted}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="6,4">
                                    <TabPanel IsItemsHost="True"
                                              Background="Transparent" />
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,10,0,0"
                                        Background="{DynamicResource CardBackground}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                                      ContentSource="SelectedContent"
                                                      Margin="0"
                                                      Opacity="1" />
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <EventTrigger RoutedEvent="Selector.SelectionChanged">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_SelectedContentHost"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0.92"
                                                             To="1"
                                                             Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StarFireTabItemStyle" TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="FontWeight" Value="Normal" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Padding" Value="16,10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="TabBorder"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    BorderThickness="0,0,0,3"
                                    CornerRadius="8"
                                    Margin="0,0,6,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabHoverBackground}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource CardBackground}" />
                                    <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource PrimaryRed}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ClienteFilterTabControlStyle" TargetType="TabControl">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabControl">
                            <Border Background="{DynamicResource SurfaceMuted}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="6,4">
                                <TabPanel IsItemsHost="True" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ClienteFilterTabItemStyle" TargetType="TabItem">
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="18,8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TabItem">
                            <Border x:Name="FilterTabBorder"
                                    Background="Transparent"
                                    CornerRadius="8"
                                    Margin="0,0,8,0"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="FilterTabBorder" Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="FilterTabBorder" Property="Background" Value="{DynamicResource CardBackground}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NotificationBellToggleStyle" TargetType="ToggleButton">
                <Setter Property="Width" Value="40" />
                <Setter Property="Height" Value="36" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                <Setter Property="Background" Value="{DynamicResource ControlBackground}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="BellRoot"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BellRoot" Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                                    <Setter TargetName="BellRoot" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="BellRoot" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                    <Setter TargetName="BellRoot" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NotificationItemButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Height" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Margin" Value="0,0,0,10" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12">
                                <ContentPresenter Margin="0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlueBorder}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource ControlBackground}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="NotificationTypeBadgeBorderStyle" TargetType="Border">
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="{DynamicResource ControlBackgroundHover}" />
                <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}" />
            </Style>

            <Style x:Key="NotificationTypeBadgeTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11.5" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Tipo}" Value="Pagamento">
                        <Setter Property="Foreground" Value="{DynamicResource AccentBlueFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tipo}" Value="Extintor">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeWarningFg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding Tipo}" Value="Alvará">
                        <Setter Property="Foreground" Value="{DynamicResource BadgeDangerFg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="NotificationSeverityStripStyle" TargetType="Border">
                <Setter Property="Width" Value="4" />
                <Setter Property="Background" Value="{DynamicResource BadgeWarningBg}" />
                <Setter Property="CornerRadius" Value="12,0,0,12" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="Vencido">
                        <Setter Property="Background" Value="{DynamicResource BadgeDangerBg}" />
                    </DataTrigger>
                    <DataTrigger Binding="{Binding SituacaoNivel}" Value="OK">
                        <Setter Property="Background" Value="{DynamicResource BadgeSuccessBg}" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="MainRootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE81E;"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource PrimaryRed}" />
                    <TextBlock Text="Star Fire CRM"
                               Style="{StaticResource AppTitleBarTextStyle}" />
                </StackPanel>

                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarButtonStyle}"
                        Click="MinimizeButton_Click"
                        Content="&#xE921;" />
                <Button Grid.Column="3"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Height="100"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                Effect="{StaticResource HeaderShadow}">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/Assets/Images/startfire.png"
                       Width="68"
                       Height="68"
                       Stretch="Uniform"
                       Margin="0,0,16,0"
                       VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Star Fire CRM"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryRed}" />
                    <TextBlock Text="Gestão de Clientes e Vencimentos"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondary}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <Grid Margin="0,0,10,0">
                        <ToggleButton x:Name="NotificationBellButton"
                                      Style="{StaticResource NotificationBellToggleStyle}"
                                      IsChecked="{Binding IsNotificationPanelOpen, Mode=TwoWay}">
                            <TextBlock FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE7ED;"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextPrimary}" />
                        </ToggleButton>
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-4,-4,0"
                                Padding="6,1"
                                CornerRadius="9"
                                Background="{DynamicResource PrimaryRed}"
                                BorderBrush="{DynamicResource PrimaryRedHover}"
                                BorderThickness="1"
                                Visibility="{Binding HasPendingNotifications, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding PendingNotificationCount}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource ButtonPrimaryFg}" />
                        </Border>

                        <Popup IsOpen="{Binding IsNotificationPanelOpen, Mode=TwoWay}"
                               PlacementTarget="{Binding ElementName=NotificationBellButton}"
                               Placement="Bottom"
                               VerticalOffset="8"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Width="410"
                                    Padding="16"
                                    CornerRadius="12"
                                    Background="{DynamicResource CardBackground}"
                                    BorderBrush="{DynamicResource ControlBorder}"
                                    BorderThickness="1"
                                    Effect="{StaticResource SoftShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                                   Text="&#xE7ED;"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryRed}" />
                                        <TextBlock Grid.Column="1"
                                                   Margin="8,0,0,0"
                                                   Text="Mais urgentes"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimary}" />
                                        <Border Grid.Column="2"
                                                Padding="8,2"
                                                CornerRadius="999"
                                                Background="{DynamicResource SurfaceMuted}"
                                                BorderBrush="{DynamicResource BorderSubtle}"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding PendingNotificationCount, StringFormat={}{0} itens}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary}" />
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Margin="0,10,0,8"
                                            Height="1"
                                            Background="{DynamicResource BorderSubtle}" />

                                    <ScrollViewer Grid.Row="2"
                                                  Margin="0,2,0,10"
                                                  MaxHeight="320"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding BellNotificationItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Style="{StaticResource NotificationItemButtonStyle}"
                                                            Command="{Binding DataContext.OpenDashboardItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="4" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Grid.Column="0"
                                                                    Style="{StaticResource NotificationSeverityStripStyle}" />

                                                            <Grid Grid.Column="1"
                                                                  Margin="12,10,12,10">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <TextBlock Text="{Binding ClienteNome}"
                                                                           Grid.Row="0"
                                                                           Grid.Column="0"
                                                                           Margin="0,0,10,0"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource TextPrimary}"
                                                                           TextTrimming="CharacterEllipsis" />

                                                                <Border Grid.Row="0"
                                                                        Grid.Column="1"
                                                                    Style="{StaticResource StatusBadgeBorderStyle}"
                                                                    VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding SituacaoTexto}"
                                                                               Style="{StaticResource StatusBadgeTextStyle}" />
                                                                </Border>

                                                                <StackPanel Grid.Row="1"
                                                                            Grid.ColumnSpan="2"
                                                                            Orientation="Horizontal"
                                                                            Margin="0,8,0,0">
                                                                    <Border Style="{StaticResource NotificationTypeBadgeBorderStyle}">
                                                                        <TextBlock Text="{Binding Tipo, Mode=OneWay}"
                                                                                   Style="{StaticResource NotificationTypeBadgeTextStyle}" />
                                                                    </Border>
                                                                    <TextBlock Margin="10,0,0,0"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource TextSecondary}"
                                                                               Text="{Binding DataVencimentoTexto, Mode=OneWay, StringFormat=Vencimento: {0}}" />
                                                                </StackPanel>

                                                                <TextBlock Grid.Row="2"
                                                                           Grid.ColumnSpan="2"
                                                                           Margin="0,6,0,0"
                                                                           Foreground="{DynamicResource TextMuted}"
                                                                           FontSize="12"
                                                                           Text="{Binding DiasTexto, Mode=OneWay, StringFormat=Dias para vencer: {0}}" />
                                                            </Grid>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <TextBlock Grid.Row="2"
                                               Text="Sem notificações no momento."
                                               Foreground="{DynamicResource TextSecondary}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Visibility="Collapsed">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BellNotificationItems.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Grid.Row="3"
                                            Style="{StaticResource AccentButton}"
                                            Height="34"
                                            HorizontalAlignment="Right"
                                            MinWidth="126"
                                            Command="{Binding GoToDashboardCommand}">
                                        <StackPanel Style="{StaticResource IconButtonContent}">
                                            <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xEA39;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                            <TextBlock Text="Ver no painel" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <Border Background="{DynamicResource SurfaceMuted}" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1" CornerRadius="10" Padding="10,6" Margin="0,0,10,0">
                        <TextBlock Text="{Binding AppVersionDisplay}" Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl x:Name="MainTabs"
                    Grid.Row="2"
                    Margin="24,14,24,24"
                    Style="{StaticResource StarFireTabControlStyle}"
                    ItemContainerStyle="{StaticResource StarFireTabItemStyle}"
                    SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}">
            <TabItem Header="Dashboard">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="18">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Dashboard" FontSize="24" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                                    <TextBlock Text="Visão geral dos vencimentos e cobranças" Foreground="{DynamicResource TextSecondary}" Margin="0,6,0,0" />
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Style="{StaticResource SecondaryButton}"
                                        MinWidth="112"
                                        Height="38"
                                        Click="HelpButton_Click"
                                        Tag="Dashboard">
                                    <StackPanel Style="{StaticResource IconButtonContent}">
                                        <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE897;" />
                                        <TextBlock Text="Ajuda" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Border Style="{StaticResource DashboardHeroCardStyle}" Margin="0,18,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Panorama operacional" FontSize="18" FontWeight="SemiBold" />
                                        <TextBlock Text="Monitoramento de extintores, alvarás e cobranças em tempo real." Margin="0,6,0,12" Foreground="{DynamicResource TextSecondary}" />
                                        <WrapPanel>
                                            <Border Style="{StaticResource NotificationTypeBadgeBorderStyle}" Margin="0,0,8,0">
                                                <TextBlock Text="Extintores" Style="{StaticResource NotificationTypeBadgeTextStyle}" />
                                            </Border>
                                            <Border Style="{StaticResource NotificationTypeBadgeBorderStyle}" Margin="0,0,8,0">
                                                <TextBlock Text="Alvarás" Style="{StaticResource NotificationTypeBadgeTextStyle}" />
                                            </Border>
                                            <Border Style="{StaticResource NotificationTypeBadgeBorderStyle}">
                                                <TextBlock Text="Pagamentos" Style="{StaticResource NotificationTypeBadgeTextStyle}" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>

                                    <Border Grid.Row="1" Margin="0,14,0,0" Padding="0,14,0,0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,1,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Ações rápidas" FontSize="15.5" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <WrapPanel x:Name="DashboardQuickActionsPanel" VerticalAlignment="Center">
                                            <Button Style="{StaticResource QuickActionButtonStyle}" Margin="0,0,10,0" Command="{Binding GoToClientesCommand}">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE716;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    <TextBlock Text="Ver clientes" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{StaticResource QuickActionAccentButtonStyle}" Command="{Binding GoToPagamentosCommand}">
                                                <StackPanel Style="{StaticResource IconButtonContent}">
                                                    <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE8B5;" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                    <TextBlock Text="Ver pagamentos" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                </StackPanel>
                                            </Button>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <WrapPanel x:Name="DashboardKpiPanel"
                                   Margin="0,0,0,20"
                                   Orientation="Horizontal"
                                   ItemHeight="168"
                                   ItemWidth="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ActualWidth, Converter={StaticResource DashboardKpiItemWidthConverter}}">
                            <Border Style="{StaticResource KpiCardDangerStyle}" Margin="0,0,10,10" Cursor="Hand" ToolTip="Clique para listar os clientes deste aviso">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenDashboardAlertsCommand}" CommandParameter="ext-vencidos" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Style="{StaticResource KpiTopStripDangerStyle}" Margin="0,0,0,0" />
                                    <Border Style="{StaticResource KpiOrbStyle}" Background="{DynamicResource KpiDangerOrbFill}" />
                                    <Border Style="{StaticResource KpiHoverSheenStyle}" />
                                    <DockPanel LastChildFill="False" Margin="0,6,0,0">
                                        <Border Style="{StaticResource KpiIconWrapStyle}" Background="{DynamicResource BadgeDangerBg}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Text="&#xE814;" Foreground="{DynamicResource BadgeDangerFg}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border DockPanel.Dock="Right" Style="{StaticResource KpiSeverityBadgeStyle}" Background="{DynamicResource BadgeDangerBg}" BorderBrush="{DynamicResource BorderColor}">
                                            <TextBlock Style="{StaticResource KpiBadgeTextStyle}" Text="Crítico" Foreground="{DynamicResource BadgeDangerFg}" />
                                        </Border>
                                    </DockPanel>
                                    <StackPanel Grid.Row="1" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding Dashboard.ExtintoresVencidos}" Style="{StaticResource KpiValueTextStyle}" />
                                        <TextBlock Text="Extintores vencidos" Style="{StaticResource KpiLabelTextStyle}" />
                                        
                                        <DockPanel Style="{StaticResource KpiMetaRowStyle}">
                                            <TextBlock Style="{StaticResource KpiMetaTextStyle}" Text="Abrir lista" />
                                            <TextBlock Style="{StaticResource KpiMetaGlyphStyle}" DockPanel.Dock="Right" Margin="8,0,0,0" Text="&#xE76C;" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource KpiCardWarningStyle}" Margin="0,0,10,10" Cursor="Hand" ToolTip="Clique para listar os clientes deste aviso">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding OpenDashboardAlertsCommand}" CommandParameter="ext-vencendo7" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Style="{StaticResource KpiTopStripWarningStyle}" Margin="0,0,0,0" />
                                    <Border Style="{StaticResource KpiOrbStyle}" Background="{DynamicResource KpiWarningOrbFill}" />
                                    <Border Style="{StaticResource KpiHoverSheenStyle}" />
                                    <DockPanel LastChildFill="False" Margin="0,6,0,0">
                                        <Border Style="{StaticResource KpiIconWrapStyle}" Background="{DynamicResource BadgeWarningBg}">
                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" FontWeight="SemiBold" Text="&#xE823;" Foreground="{DynamicResource BadgeWarningFg}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border DockPanel.Dock="Right" Style="{StaticResource KpiSeverityBadgeStyle}" Background="{DynamicResource BadgeWarningBg}" BorderBrush="{DynamicResource BorderColor}">
                                            <TextBlock Style="{StaticResource KpiBadgeTextStyle}" Text="Atenção" Foreground="{DynamicResource BadgeWarningFg}" />
                                        </Border>
                                    </DockPanel>
