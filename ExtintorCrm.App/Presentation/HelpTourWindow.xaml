<Window x:Class="ExtintorCrm.App.Presentation.HelpTourWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajuda"
        Width="640"
        Height="430"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.18" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource AppTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="WindowTitleText"
                           Text="Ajuda da tela"
                           Style="{StaticResource AppTitleBarTextStyle}" />
                <Button Grid.Column="1"
                        Style="{StaticResource AppTitleBarCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Border Style="{StaticResource CardStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="TourTitleText"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" />

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                Margin="0,8,0,12">
                        <Border Background="{DynamicResource SurfaceMuted}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="999"
                                Padding="10,4">
                            <TextBlock x:Name="StepCounterText"
                                       Style="{StaticResource CaptionText}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary}" />
                        </Border>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Background="{DynamicResource SurfaceMuted}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="StepDescriptionText"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextPrimary}" />
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="3" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PreviousButton"
                                Grid.Column="0"
                                Style="{StaticResource SecondaryButton}"
                                MinWidth="118"
                                Margin="0,0,10,0"
                                Click="PreviousButton_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE76B;" />
                                <TextBlock Text="Anterior" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NextButton"
                                Grid.Column="1"
                                Style="{StaticResource SecondaryButton}"
                                MinWidth="118"
                                Click="NextButton_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Text="Próximo" />
                                <TextBlock Style="{StaticResource ToolbarIconStyle}" Text="&#xE76C;" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="3"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="126"
                                Click="CloseButton_Click">
                            <StackPanel Style="{StaticResource IconButtonContent}">
                                <TextBlock Style="{StaticResource ToolbarIconStyle}"
                                           Text="&#xE8BB;"
                                           Foreground="{DynamicResource ButtonPrimaryFg}" />
                                <TextBlock Text="Fechar"
                                           Foreground="{DynamicResource ButtonPrimaryFg}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

