<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackground" Color="#E8F0FA" />
    <SolidColorBrush x:Key="SurfaceBackground" Color="#DDE8F5" />
    <SolidColorBrush x:Key="CardBackground" Color="#FCFEFF" />
    <SolidColorBrush x:Key="ControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBackgroundHover" Color="#EDF5FF" />
    <SolidColorBrush x:Key="ControlBorder" Color="#C3D4E7" />
    <SolidColorBrush x:Key="TextPrimary" Color="#162234" />
    <SolidColorBrush x:Key="TextSecondary" Color="#4A5E79" />
    <SolidColorBrush x:Key="TextMuted" Color="#7E90AA" />
    <SolidColorBrush x:Key="PrimaryRed" Color="#C94848" />
    <SolidColorBrush x:Key="PrimaryRedHover" Color="#AD3A3A" />
    <SolidColorBrush x:Key="AccentBlueBg" Color="#E5EEFC" />
    <SolidColorBrush x:Key="AccentBlueBorder" Color="#4F7BC9" />
    <SolidColorBrush x:Key="AccentBlueFg" Color="#1F4B8E" />
    <SolidColorBrush x:Key="DangerBorder" Color="#C24141" />
    <SolidColorBrush x:Key="DangerFg" Color="#A73030" />
    <SolidColorBrush x:Key="DisabledBg" Color="#D6DEE9" />
    <SolidColorBrush x:Key="DisabledFg" Color="#8A99AE" />

    <SolidColorBrush x:Key="BorderColor" Color="#C9D8EA" />
    <SolidColorBrush x:Key="InputBackground" Color="#FDFEFF" />
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#E4EEFA" />
    <SolidColorBrush x:Key="RowHoverBackground" Color="#E5F0FF" />
    <SolidColorBrush x:Key="RowSelectedBackground" Color="#D7E6FD" />
    <SolidColorBrush x:Key="SurfaceMuted" Color="#E3ECF8" />
    <SolidColorBrush x:Key="TabHoverBackground" Color="#E7F1FE" />

    <SolidColorBrush x:Key="BadgeSuccessBg" Color="#D9F6E5" />
    <SolidColorBrush x:Key="BadgeSuccessFg" Color="#1F6E48" />
    <SolidColorBrush x:Key="BadgeWarningBg" Color="#FEF1D3" />
    <SolidColorBrush x:Key="BadgeWarningFg" Color="#8F5D17" />
    <SolidColorBrush x:Key="BadgeDangerBg" Color="#FBE0E0" />
    <SolidColorBrush x:Key="BadgeDangerFg" Color="#8B2E2E" />
    <SolidColorBrush x:Key="BadgeMutedBg" Color="#E8EEF5" />
    <SolidColorBrush x:Key="BadgeMutedFg" Color="#344760" />
    <LinearGradientBrush x:Key="KpiDangerCardBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFDFD" Offset="0" />
        <GradientStop Color="#FCEFEF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="KpiWarningCardBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFD" Offset="0" />
        <GradientStop Color="#FDF4E3" Offset="1" />
    </LinearGradientBrush>
    <RadialGradientBrush x:Key="KpiDangerOrbFill" Center="0.35,0.35" GradientOrigin="0.35,0.35" RadiusX="0.75" RadiusY="0.75">
        <GradientStop Color="#B8F7CACA" Offset="0" />
        <GradientStop Color="#00F7CACA" Offset="1" />
    </RadialGradientBrush>
    <RadialGradientBrush x:Key="KpiWarningOrbFill" Center="0.35,0.35" GradientOrigin="0.35,0.35" RadiusX="0.75" RadiusY="0.75">
        <GradientStop Color="#B8F8DEAA" Offset="0" />
        <GradientStop Color="#00F8DEAA" Offset="1" />
    </RadialGradientBrush>
    <Color x:Key="ShadowColor">#0B1424</Color>

    <SolidColorBrush x:Key="SfRed" Color="#C63E3E" />
    <SolidColorBrush x:Key="SfRedHover" Color="#A43232" />
    <SolidColorBrush x:Key="SfGold" Color="#D4AF37" />
    <SolidColorBrush x:Key="SfSuccess" Color="#1F8E55" />
    <SolidColorBrush x:Key="SfWarning" Color="#C08B2E" />
    <SolidColorBrush x:Key="SfError" Color="#C24141" />
    <SolidColorBrush x:Key="SfBg" Color="#EEF3FA" />
    <SolidColorBrush x:Key="SfCardBg" Color="#F8FBFF" />
    <SolidColorBrush x:Key="SfBorder" Color="#CFDAE7" />
    <SolidColorBrush x:Key="SfTextPrimary" Color="#162234" />
    <SolidColorBrush x:Key="SfTextSecondary" Color="#4F5F76" />

    <SolidColorBrush x:Key="ActionAccentBg" Color="#2D66C4" />
    <SolidColorBrush x:Key="ActionAccentHover" Color="#2756A8" />
    <SolidColorBrush x:Key="ActionAccentBorder" Color="#3A72CC" />

    <LinearGradientBrush x:Key="TitleBarBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E7EFF9" Offset="0" />
        <GradientStop Color="#D8E4F1" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="TitleBarBorder" Color="#B3C6DF" />
    <LinearGradientBrush x:Key="TitleBarButtonBg" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F8FBFF" Offset="0" />
        <GradientStop Color="#EAF2FC" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="TitleBarButtonHoverBg" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#ECF4FF" Offset="0" />
        <GradientStop Color="#DEEAFA" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FCFEFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#E8F0FA" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlLightLightBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkBrushKey}" Color="#C3D4E7" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlDarkDarkBrushKey}" Color="#AFC2DA" />
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#162234" />
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="#162234" />
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}" Color="#7B8EAA" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#C94848" />
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuBrushKey}" Color="#F8FBFF" />
    <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#162234" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#D7E6FD" />
    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#162234" />
</ResourceDictionary>
