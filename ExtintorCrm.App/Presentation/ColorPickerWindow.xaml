<Window x:Class="ExtintorCrm.App.Presentation.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar cor"
        Width="540"
        Height="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBackground}"
        FontFamily="Segoe UI Variable"
        FontSize="14"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.22"
                                     EasingFunction="{StaticResource DialogEaseOut}" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource DialogTitleBarStyle}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="WindowTitleText"
                           Style="{StaticResource DialogTitleTextStyle}"
                           Text="Selecionar cor" />
                <Button Grid.Column="1"
                        Style="{StaticResource DialogCloseButtonStyle}"
                        Click="CloseButton_Click"
                        Content="&#xE8BB;" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="18"
                Padding="16"
                Style="{StaticResource DialogAnimatedCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Arraste o ponto no gradiente para definir a cor."
                           Foreground="{DynamicResource TextSecondary}" />

                <Border x:Name="PreviewColorBorder"
                        Grid.Row="1"
                        Height="72"
                        Margin="0,12,0,0"
                        CornerRadius="12"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource ControlBorder}" />

                <TextBlock x:Name="HexValueText"
                           Grid.Row="2"
                           Margin="0,8,0,0"
                           FontSize="22"
                           FontWeight="SemiBold"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimary}" />

                <Grid Grid.Row="3" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="12"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlBorder}">
                        <Grid x:Name="SaturationValueArea"
                              ClipToBounds="True"
                              Background="Transparent"
                              MouseLeftButtonDown="SaturationValueArea_MouseLeftButtonDown"
                              MouseMove="SaturationValueArea_MouseMove"
                              MouseLeftButtonUp="SaturationValueArea_MouseLeftButtonUp"
                              SizeChanged="SaturationValueArea_SizeChanged">
                            <Rectangle x:Name="SaturationValueHueLayer" />
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                                        <GradientStop Color="#00FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#00FFFFFF" Offset="0" />
                                        <GradientStop Color="#FF000000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Canvas IsHitTestVisible="False">
                                <Ellipse x:Name="SaturationValueSelector"
                                         Width="14"
                                         Height="14"
                                         Stroke="#FFFFFFFF"
                                         StrokeThickness="2"
                                         Fill="#22000000" />
                            </Canvas>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlBorder}">
                        <Grid x:Name="HueArea"
                              ClipToBounds="True"
                              Background="Transparent"
                              MouseLeftButtonDown="HueArea_MouseLeftButtonDown"
                              MouseMove="HueArea_MouseMove"
                              MouseLeftButtonUp="HueArea_MouseLeftButtonUp"
                              SizeChanged="HueArea_SizeChanged">
                            <Rectangle RadiusX="8" RadiusY="8">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FFFF0000" Offset="0" />
                                        <GradientStop Color="#FFFFFF00" Offset="0.17" />
                                        <GradientStop Color="#FF00FF00" Offset="0.33" />
                                        <GradientStop Color="#FF00FFFF" Offset="0.50" />
                                        <GradientStop Color="#FF0000FF" Offset="0.67" />
                                        <GradientStop Color="#FFFF00FF" Offset="0.83" />
                                        <GradientStop Color="#FFFF0000" Offset="1" />
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Canvas IsHitTestVisible="False">
                                <Border x:Name="HueSelector"
                                        Width="28"
                                        Height="4"
                                        CornerRadius="2"
                                        Background="#FFFFFFFF"
                                        BorderBrush="#88000000"
                                        BorderThickness="1" />
                            </Canvas>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,12,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            Width="118"
                            Margin="0,0,8,0"
                            Click="CancelButton_Click">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path  Style="{StaticResource ToolbarVectorIconStyle}" Data="{StaticResource IconCloseGeometry}" />
                            <TextBlock Text="Cancelar" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}"
                            Width="118"
                            Click="ApplyButton_Click">
                        <StackPanel Style="{StaticResource IconButtonContent}">
                            <Path Style="{StaticResource ToolbarVectorIconPrimaryStyle}" Data="{StaticResource IconCheckGeometry}" />
                            <TextBlock Text="Aplicar"
                                       Foreground="{DynamicResource ButtonPrimaryFg}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>


